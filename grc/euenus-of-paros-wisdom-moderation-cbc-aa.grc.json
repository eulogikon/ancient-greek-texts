  "research_html": "<div class=\"research-section\">\n<p class=\"research-text\"><strong>On Wisdom and Moderation</strong> is a collection of gnomic verses attributed to the sophist and poet Euenus of Paros, a late-5th-century BCE contemporary of Socrates. The work survives only in fragments, preserved through quotations by later authors such as Plato, Aristotle, and the anthologist Stobaeus. The surviving passages offer pithy sayings on ethics and practical life, composed in verse for didactic purposes. The fragments address core sophistic and ethical themes, including the cultivation of wisdom as the foundation of the good life, the central importance of moderation and self-control, and practical advice on daily conduct, friendship, and personal affairs. No independent manuscript tradition exists for the work; the text is reconstructed entirely from fragments cited by later philosophers and compilers, with modern standard editions found in the collections <strong>Poetae Melici Graeci</strong> and <strong>Iambi et Elegi Graeci</strong>. Euenus&#x27;s verses were integrated into classical philosophical discourse, quoted by both Plato and Aristotle in their ethical discussions. This citation by major figures demonstrates the work&#x27;s role in the pre-Socratic and sophistic tradition of using poetry for ethical instruction, before its influence was absorbed by systematic philosophy.</p>\n</div>",
  "rows": [
    {
      "kind": "text",
      "reference": "book 1.1",
      "text": "πολλοῖς δ’ ἀντιλέγειν (μέν)[ln_1]ἔθος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.2",
      "text": "περὶ παντὸς ὁμοίως, [para]ὀρθῶς δ’ ἀντιλέγειν, οὐκέτι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.3",
      "text": "τοῦτ’ ἐν ἔθει. καὶ πρὸς μὲν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.4",
      "text": "τούτους ἀρκεῖ λόγος εἷς ὁ παλαιός· [para]“σοὶ μὲν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.5",
      "text": "ταῦτα δοκοῦντ’ ἔστω, ἐμοὶ δὲ τάδε.”[ln_5]τοὺς ξυνετοὺς δ’ ἄν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.6",
      "text": "τις",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.7",
      "text": "πείσειε τάχιστα λέγων εὖ, οἵπερ καὶ ῥήιστης εἰσὶ διδασκαλίης.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.1",
      "text": "Βάκχου μέτρον ἄριστον ὃ μὴ πολὺ μηδ’ ἐλάχιστον· [para]ἔστι γὰρ ἢ λύπης αἴτιος ἢ μανίης. χαίρει κιρνάμενος δὲ τρισὶν Νύμφαισι τέταρτος· [para]τῆμος καὶ θαλάμοις ἐστὶν ἑτοιμότατος.[ln_5]εἰ δὲ πολὺς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.2",
      "text": "πνεύσειεν, ἀπέστραπται μὲν ἔρωτας, [para]βαπτίζει δ’ ὕπνωι, γείτονι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.3",
      "text": "τοῦ θανάτου.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.1",
      "text": "ἡγοῦμαι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.2",
      "text": "σοφίης εἶναι μέρος οὐκ ἐλάχιστον [para]ὀρθῶς γινώσκειν οἷος ἕκαστος ἀνήρ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 4.1",
      "text": "πρὸς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 4.2",
      "text": "σοφίηι μὲν ἔχειν τόλμαν μάλα σύμφορόν ἐστιν· [para]χωρὶς δὲ βλαβερή, καὶ κακότητα φέρει.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 5",
      "text": "πολλάκις ἀνθρώπων ὀργὴ νόον ἐξεκάλυψεν [para]κρυπτόμενον· μανίης πολὺ χειρότερον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 6.1",
      "text": "ἢ δέος ἢ λύπη",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 6.2",
      "text": "παῖς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 6.3",
      "text": "πατρὶ πάντα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 6.4",
      "text": "χρόνον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 7",
      "text": "ἥτις κερδαίνους’ οὐδὲν ὅμως ἀδικεῖ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 8.1",
      "text": "πᾶν γὰρ ἀναγκαῖον",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 8.2",
      "text": "πρᾶγμ’ ἀνιηρὸν ἔφυ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 9.1",
      "text": "φημὶ πολυχρόνιον μελέτην ἔμεναι φίλε, καὶ δὴ ταύτην ἀνθρώποισι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 9.2",
      "text": "τελευτῶσαν φύσιν εἶναι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 9a.1",
      "text": "σοφώτατόν",
      "witness_prefix": "",
      "speaker": null
    },
    {
