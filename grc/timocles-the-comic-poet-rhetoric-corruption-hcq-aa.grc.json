      "kind": "text",
      "reference": "book 14.5",
      "text": "σαργάνας[ln_5]αὐτήν· ταρίχους εὐπόρως γὰρ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 14.6",
      "text": "τυγχάνει ἔχουσα καὶ σύνεστι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 14.7",
      "text": "σαπέρδαις δυσίν, καὶ ταῦτ’ ἀνάλτοις καὶ πλατυρρύγχοις",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 14.8",
      "text": "τισίν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 15.1",
      "text": "τόν τ’ ἰχθυόρρουν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 15.2",
      "text": "ποταμὸν Ὑπερείδην",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 15.3",
      "text": "περᾷς, ὃς ἠπίαις",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 15.4",
      "text": "φωναῖσιν ἔμφρονος λόγου κόμποις",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 15.5",
      "text": "παφλάζων ἠπίοις",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 15.6",
      "text": "πυκνώμασιν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 15.7",
      "text": "πρὸς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 15.8",
      "text": "πανδυσας ἔχει,[ln_5]μισθωτὸς ἄρδει",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 15.9",
      "text": "πεδία",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 15.10",
      "text": "τοῦ δεδωκότος.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 16.1",
      "text": "ὥστ’ ἔχειν οὐδὲν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 16.2",
      "text": "παρ’ ἡμῖν· νυκτερεύσας δ’ ἀθλίως",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 16.3",
      "text": "πρῶτα μὲν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 16.4",
      "text": "σκληρῶς καθεῦδον, εἶτα Θούδιππος βδέων",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 16.5",
      "text": "παντελῶς ἔπηξεν ἡμᾶς, εἶθ’ ὁ λιμὸς ἥπτετο. ἐφέρετο",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 16.6",
      "text": "πρὸς Δίωνα τὸν διάπυρον· ἀλλὰ γὰρ[ln_5]οὐδ’ ἐκεῖνος οὐδὲν εἶχε. πρὸς δὲ τὸν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 16.7",
      "text": "χρηστὸν δραμὼν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 16.8",
      "text": "Τηλέμαχον Ἀχαρνέα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 16.9",
      "text": "σωρόν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 16.10",
      "text": "τε κυάμων καταλαβὼν ἁρπάσας",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 16.11",
      "text": "τούτων ἐνέτραγον. ὁ δ’ ὄνος ἡμᾶς ὡς ὁρᾷ, (ὡσπερεὶ) Κηφισόδωρος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 16.12",
      "text": "περὶ τὸ βῆμ’, ἐπέρδετο.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 18.1",
      "text": "ἤδη",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 18.2",
      "text": "προσενήνεκται; τί μέλλεις; σπεύδετε, ὦ ’τάν. ὁ γὰρ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 18.3",
      "text": "Τιθύμαλλος οὕτως ἀνεβίω κομιδῆ τεθνηκώς, τῶν ἀν’ ὀκτὼ τοὐβολοῦ θέρμους μαλάξας. οὐκ ἀπεκαρτέρησε γὰρ[ln_5]ἐκεῖνος, ἀλλ’ ἐκαρτέρης’, ὦ φίλτατε, πεινῶν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 19",
      "text": "Τιθύμαλλον αὐτὸν καὶ παράσιτον ἀποκαλῶν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 20.1",
      "text": "πατάξω τ’ ἴσον ἴσῳ ποτηρίοις μεγάλοις ἅπασαν τὴν ἀλήθειαν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 20.2",
      "text": "φράσαι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.1",
      "text": "μετὰ τοῦτον αὐτῷ Τηλέμαχος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.2",
      "text": "συνετύγχανεν. καὶ τοῦτον ἀσπασάμενος ἡδέως πάνυ ἔπειτα ‘χρῆσόν μοι σύ, φησί, τὰς χύτρας ἐν αἷσιν ἧψες",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.3",
      "text": "τοὺς κυάμους.‘ καὶ ταῦτά τε[ln_5]εἴρητο καὶ παριόντα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.4",
      "text": "Φείδιππον πάνυ τὸν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.5",
      "text": "Χαιρεφίλου πόρρωθεν ἀπιδὼν τὸν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.6",
      "text": "παχὺν ἐπόππυς’, εἶτ’ ἐκέλευσε πέμπειν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.7",
      "text": "σαργάνας.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 22",
      "text": "ὅσον τὸ μεταξὺ μετὰ κορίσκης ἢ μετὰ χαμαιτύπης τὴν νύκτα κοιμᾶσθαι, βαβαί. ἡ στιφρότης, τὸ χρῶμα, πνεῦμα, δαίμονες, τὸ μὴ σφόδρ’ εἶναι πάνθ’ ἕτοιμα, δεῖν δέ τι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 22.1",
      "text": "[ln_5][spk_β]ἀγωνιᾶσαι καὶ ῥαπισθῆναί τε καὶ πληγὰς λαβεῖν ἁπαλαῖσι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 22.2",
      "text": "χερσίν. Β. ἡδύ γε νὴ τὸν Δία τὸν μέγιστον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 23.1",
      "text": "ἀλλ’ ἔγωγ’ ὁ δυστυχὴς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 23.2",
      "text": "Φρύνης ἐρασθείς, ἡνίκ’ ἔτι τὴν κάππαριν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 23.3",
      "text": "συνέλεγεν οὔπω τ’ εἶχεν ὅσαπερ νῦν ἔχει, πάμπολλ’ ἀναλίσκων ἐφ’ ἑκάστῳ τῆς θύρας[ln_5]ἀπεκλῃόμην.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 24.1",
      "text": "ἔπειτα διά τε",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 24.2",
      "text": "ταῦτ’ ἀναρίστητος ὤν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 25.1",
      "text": "περὶ δὲ τὸν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 25.2",
      "text": "πανάθλιον εὕδουσι γρᾶες, Νάννιον, Πλαγγών, Λύκα, Γνάθαινα, Φρύνη, Πυθιονίκη, Μυρρίνη, Χρυσίς, Κοναλλίς, Ἱερόκλεια, Λοπάδιον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 27.1",
      "text": "εἶθ’ ὁ Καλλιμέδων ἄφνω ὁ Κάραβος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 27.2",
      "text": "προσῆλθεν, ἐμβλέπων δ’ ἐμοί, ὡς γοῦν ἐδόκει, πρὸς ἕτερον ἄνθρωπόν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 27.3",
      "text": "τινα ἐλάλει, συνιεὶς δ’ οὐδὲν εἰκότως ἐγὼ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 27.1",
      "text": "[ln_5][spk_β]ὧν ἔλεγεν ἐπένευον διακενῆς. Β. τῷ δ’ ἄρα βλέπουσι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 27.2",
      "text": "χωρὶς καὶ δοκοῦσιν αἱ κόραι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 28.1",
      "text": "πολλοὺς γὰρ ἐνίοθ’ ἡ πενία βιάζεται ἀνάξι’ αὑτῶν ἔργα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 28.2",
      "text": "παρὰ φύσιν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 28.3",
      "text": "ποιεῖν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 29.1",
      "text": "εὑρήσεις δὲ τῶν ἐπισιτίων",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 29.2",
      "text": "τούτων",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 29.3",
      "text": "τιν’, οἳ δειπνοῦσιν ἐσφυδωμένοι τἀλλότρι’, ἑαυτοὺς ἀντὶ κωρύκων λέπειν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 29.4",
      "text": "παρέχοντες ἀθληταῖσι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 30.1",
      "text": "ὁ Μισγόλας οὐ προσιέναι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 30.2",
      "text": "σοι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 30.3",
      "text": "φαίνεται, ἀνθοῦσι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 30.4",
      "text": "τοῖς νέοισιν ἠρεθισμένος.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 31.1",
      "text": "τοῖς μὲν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 31.2",
      "text": "τεθνεῶσιν ἔλεος ἐπιεικὴς θεός, τοῖς ζῶσι δ’ ἕτερον ἀνοσιώτατος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 31.3",
      "text": "φθόνος.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 32.1",
      "text": "ἀνοίγετ’ ἤδη τὰς θύρας, ἵνα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 32.2",
      "text": "πρὸς τὸ φῶς ὦμεν καταφανεῖς μᾶλλον, ἐφοδεύων ἐὰν βούληθ’ ὁ γυναικονόμος τὸν ἀριθμὸν λαμβάνειν, κατὰ τὸν νόμον τὸν καινὸν ὅπερ εἴωθε δρᾶν,[ln_5]τῶν ἑστιωμένων. ἔδει δὲ τοὔμπαλιν τὰς τῶν ἀδείπνων ἐξετάζειν οἰκίας.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 33.1",
      "text": "καταμαθὼν δὲ κειμένην θερμὴν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 33.2",
      "text": "σκάφην θερμῶν ἰπνιτῶν ἤσθιον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 34.1",
      "text": "ὅστις",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 34.2",
      "text": "φοβεῖται τὸν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 34.3",
      "text": "πατέρα κᾀσχύνεται, οὕτως",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 34.4",
      "text": "πολίτης ἀγαθὸς ἔσται κατὰ λόγον, καὶ τοὺς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 34.5",
      "text": "πολεμίους δυνάμενος κακῶς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 34.6",
      "text": "ποιεῖν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 35.1",
      "text": "τἀργύριόν ἐστιν αἷμα καὶ ψυχὴ βροτοῖς. ὅστις δὲ μὴ ἔχει",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 35.2",
      "text": "τοῦτο μηδ’ ἐκτήσατο, οὗτος μετὰ ζώντων",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 35.3",
      "text": "τεθνηκὼς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 35.4",
      "text": "περιπατεῖ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 36",
      "text": "[spk_β]σῦκ’, ἔλαιον, ἰσχάδας, μέλι. Β. σὺ μὲν εἰρεσιώνην, οὐ γεωργίαν λέγεις.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 37.1",
      "text": "Χῖοι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 37.2",
      "text": "πολὺ ἄριστ’ ἀνευρήκασιν ὀψαρτυτικήν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 38",
      "text": "μὰ γῆν, μὰ κρήνας, μὰ ποταμούς, μὰ νάματα.",
      "witness_prefix": "",
      "speaker": null
    }
  ],
