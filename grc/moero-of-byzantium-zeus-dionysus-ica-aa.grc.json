  "research_html": "<div class=\"research-section\">\n<p class=\"research-text\">The <strong>Fragments on Zeus and Dionysus</strong> is a Hellenistic epic poem composed by Moero of Byzantium, a poet active around 300 BCE. Written in dactylic hexameter, the traditional meter of Greek epic, the work presented mythological narratives centered on the gods Zeus and Dionysus. The extant fragments, preserved exclusively through quotations in Athenaeus&#x27;s <strong>The Learned Banqueters</strong>, indicate the poem included tales of divine infancy and etiological myths. One passage describes the nurturing of the infant Zeus in a Cretan cave by doves, who brought him ambrosia and nectar, with the great eagle fetching his drink. Another fragment addresses a grape cluster, heavy with the juice of Dionysus, promising it will no longer be bound by its mother vine but will sprout a nectarous leaf above its head, while also invoking the Anigrian Nymphs. The poem thus exemplifies the Hellenistic literary tendency toward erudite, allusive epic that elaborated on obscure myths and genealogies, crafted for a sophisticated readership well-versed in the classical poetic canon.</p>\n</div>",
  "rows": [
    {
      "kind": "text",
      "reference": "book 1.1",
      "text": "[ln_1]Ζεὺς δ’ ἄρ’ ἐνὶ Κρήτῃ τρέφετο μέγας, οὐδ’ ἄρα τίς νιν ἠείδει μακάρων· ὁ δ’ ἀέξετο πᾶσι μέλεσσι. Τὸν μὲν ἄρα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.2",
      "text": "τρήρωνες ὑπὸ ζαθέῳ τράφον ἄντρῳ ἀμβροσίην",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.3",
      "text": "φορέουσαι ἀπ’ Ὠκεανοῖο ῥοάων·[ln_5]νέκταρ δ’ ἐκ πέτρης μέγας αἰετὸς αἰὲν ἀφύσσων γαμφηλῇς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.4",
      "text": "φορέεσκε",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.5",
      "text": "ποτὸν Διὶ μητιόεντι. Τῷ καὶ νικήσας",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.6",
      "text": "πατέρα Κρόνον εὐρύοπα Ζεὺς ἀθάνατον",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.7",
      "text": "ποίησε καὶ οὐρανῷ ἐγκατένασσεν. Ὣς δ’ αὔτως",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.8",
      "text": "τρήρωσι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.9",
      "text": "πελειάσιν ὤπασε",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.10",
      "text": "τιμήν,[ln_10]αἳ δή τοι θέρεος καὶ χείματος ἄγγελοί εἰσιν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.1",
      "text": "Κεῖσαι δὴ χρυσέας ὑπὸ παστάδι τᾷδ’ Ἀφροδίτας [para]βότρυ, Διωνύσου",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.2",
      "text": "πληθόμενος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.3",
      "text": "σταγόνι· οὐδ’ ἔτι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.4",
      "text": "τοι μάτηρ ἐρατὸν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.5",
      "text": "περὶ κλῆμα βαλοῦσα [para]φύσει ὑπὲρ κρατὸς νεκτάρεον πέταλον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.1",
      "text": "Νύμφαι Ἀνιγριάδες, ποταμοῦ κόραι, αἳ τάδε βένθη [para]ἀμβρόσιαι ῥοδέοις",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.2",
      "text": "στείβετε",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.3",
      "text": "ποσσὶν ἀεί, χαίρετε, καὶ σῴζοιτε Κλεώνυμον, ὃς τάδε καλὰ [para]εἵσαθ’ ὑπαὶ πιτύων ὔμμι, θεαί, ξόανα.",
      "witness_prefix": "",
      "speaker": null
    }
