    {
      "kind": "text",
      "reference": "book 408",
      "text": "—〈ἀρχαίη Νύξ〉: ἀρχαία γάρ ἐστιν ἡ Νύξ, τοῦ Ἐρέβους γεννηθεῖσα. PG. cf. sch. 408.",
      "witness_prefix": "",
      "speaker": null
