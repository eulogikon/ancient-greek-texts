    {
      "kind": "text",
      "reference": "book 2.1",
      "text": "φθόνος κάκιστος κἀδικώτατος θεός, κακοῖς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.2",
      "text": "τε χαίρει κἀγαθοῖς ἀλγύνεται",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.1",
      "text": "ζευχθεὶς γάμοισιν οὐκέτ’ ἔστ’ ἐλεύθερος. ἀλλ’ ἕν γ’ ἔχει",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.2",
      "text": "τι χρηστόν· ἐν κήδει γὰρ ὤν ἐσθλῷ δέδοικε μηδὲν ἐξαμαρτάνειν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3a?.1",
      "text": "ἄριστον ἀνδρὶ κτῆμα",
      "witness_prefix": "",
      "speaker": null
    },
    {
