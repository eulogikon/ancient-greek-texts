      "reference": "book 3a?.2",
      "text": "συμπαθὴς γυνή",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 4.1",
      "text": "παίδων κρατεῖν δεῖ τῶν νεωτέρων",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 4.2",
      "text": "σοφούς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 5",
      "text": "γῆρας λεόντων κρεῖσσον ἀκμαίων νεβρῶν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 6*.1",
      "text": "γάμος κράτιστός ἐστιν ἀνδρὶ σώφρονι, τρόπον γυναικὸς",
