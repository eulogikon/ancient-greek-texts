    },
    {
      "kind": "text",
      "reference": "book 1.2",
      "text": "πλείστων",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.3",
      "text": "ποιεῖται καὶ πράσων ἀβυρτάκη.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1",
      "text": "Ἰχθύων δὲ δὴ ὑπογάστρι’ ὦ Δάματερ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.1",
      "text": "Ἠρίσταμεν· δεῖ γὰρ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.2",
      "text": "συνάπτειν τὸν λόγον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.1",
      "text": "Λεωτροφίδης ὁ τρίμετρος ὡς Λεόντινος εὔχρως",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.2",
      "text": "τε φᾶναι καὶ χαρίεις ὥσπερ νεκρός.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2",
      "text": "Ἐλεφαντοκώπους ξιφομαχαίρας καὶ δόρη.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3",
      "text": "Ἢ μετάδος ἢ μέτρησον ἢ τιμὴν λάβε.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 5",
      "text": "Κολάσομαί γέ σε καὶ τὸν σὸν Ἄττιν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.1",
      "text": "Ὥς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.2",
      "text": "ποτ’ ἐκήλησεν Καλλίστρατος υἷας Ἀχαιῶν, κέρμα φίλον διαδούς, ὅτε",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.3",
      "text": "συμμαχίαν ἐρέεινεν· οἶον δ’ οὐ κήλησε δέμας λεπτὸν Ῥαδάμανθυν Λύσανδρον, κώθωνα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.4",
      "text": "πρὶν αὐτῷ δῶκε λεπαστήν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.1",
      "text": "Παρ’ ἐμοὶ τὰ λίαν μειράκια",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.2",
      "text": "χαρίζεται",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.3",
      "text": "τοῖς ἡλικιώταις.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.1",
      "text": "Χώρει σὺ δεῦρο, Θηρικλέους",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.2",
      "text": "πιστὸν τέκνον· γενναῖον εἶδος, ὄνομά σοι τί θώμεθα; ἆρ’ εἶ κάτοπτρον φύσεος ἢν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.3",
      "text": "πλῆρες δοθῇς. οὐδέν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.4",
      "text": "ποτ’ ἄλλο. δεῦρο δὴ γεμίσω ς’ ἐγώ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.1",
      "text": "[ln_5][spk_β]γραῦ Θεολύτη, γραῦ. Β. τί με καλεῖς σὺ φίλτατε; Α. ἵν’ ἀσπάσωμαι· δεῦρο",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.2",
      "text": "παρ’ ἐμὲ Θεολύτη, παρὰ τὸν νέον ξύνδουλον· οὑτωσὶ καλῶς· Β. Σπινθὴρ τάλας, πειρᾷς με; Α. ναί, τοιοῦτό τι· φιλοτησίαν δὲ τήνδε",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.3",
      "text": "σοι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.4",
      "text": "προπίομαι·[ln_10]δέξαι, πιοῦσα δ’ ὁπόσον ἄν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.5",
      "text": "σοι θυμὸς ᾖ, παράδος τὸ πρῶτον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.1",
      "text": "Ἵνα μὴ τὸ παλαιὸν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.2",
      "text": "τοῦτο καὶ θρυλούμενον δι’ ἡμετέρων",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.3",
      "text": "στομάτων εἴπω σόφισμ’, ὅ φασι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.4",
      "text": "παῖδας Λεσβίων εὑρεῖν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2",
      "text": "Χιτῶνά μοι φέρων δέδωκας δαιδάλεον, ὃν ᾔκασεν ἄρισθ’ Ὅμηρος κρομμύου λεπυχάνῳ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3",
      "text": "Εὐριπίδου τ’ ἄριστον οὐ κακῶς ἔχον, τἀλλότρια δειπνεῖν τὸν καλῶς εὐδαίμονα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1",
      "text": "Πάντ’ ἀγαθὰ δὴ γέγονεν ἀνδράσιν ἐμῆς ἀπὸ συνουσίας.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.1",
      "text": "Τηνδὶ περιζωσάμενος ᾤαν λουτρίδα κατάδεσμον ἥβης",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.2",
      "text": "περιπέτασον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.1",
      "text": "Σπόγγος, λεκάνη, πτερόν, λεπαστὴ πάνυ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.2",
      "text": "πυκνή, ἣν ἐκπιοῦς’ ἄκρατον ἀγαθοῦ δαίμονος τέττιξ κελαδεῖ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.1",
      "text": "Λεπαστὴ μάλα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.2",
      "text": "συχνή, ἣν ἐκπιοῦς’ ἄκρατον ἀγαθοῦ δαίμονος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.3",
      "text": "περιστατὸν βοῶσα τὴν κώμην",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.4",
      "text": "ποιεῖ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.1",
      "text": "Αὐτὴ δ’ ἐκείνη",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.2",
      "text": "πρότερον ἐξηπίστατο",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.3",
      "text": "παρὰ τῆς ἐπιτηθῆς.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 4",
      "text": "Τούτων ἁπάντων ὁ ῥαχιστὴς Δημοφῶν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1",
      "text": "Καί σε τῇ νουμηνίᾳ ἀγαλματίοις ἀγαλοῦμεν ἀεὶ καὶ δάφνῃ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.1",
      "text": "Καὶ τὴν ἱερὰν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.2",
      "text": "σφάττουσιν ἡμῶν δέλφακα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.1",
      "text": "Θύννων",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.2",
      "text": "τε λευκῶν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.3",
      "text": "Σικελικῶν ὑπήτρια.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.1",
      "text": "Αὐλεῖ γὰρ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.2",
      "text": "σαπρὰ αὕτη γε κρούμαθ’ οἷα τἀπὶ Χαριξένης.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.1",
      "text": "Ὑποδοῦ λαβὼν τὰς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.2",
      "text": "περιβαρίδας.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 4",
      "text": "Φρυγεύς, θυεία, λήκυθος.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.1",
      "text": "Ἐγὼ γὰρ ἂν κώθωνος ἐκ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.2",
      "text": "στρεψαύχενος πίοιμι τὸν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.3",
      "text": "τράχηλον ἀνακεκλασμένη.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.1",
      "text": "Καί τοι τίς οὐκ ἂν εἰκὸς εὖ πράττοι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.2",
      "text": "τετρωβολίζων, εἰ νῦν γε διώβολον φέρων ἀνὴρ",
      "witness_prefix": "",
      "speaker": null
