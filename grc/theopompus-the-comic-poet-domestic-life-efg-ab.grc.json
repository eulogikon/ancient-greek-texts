      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.1",
      "text": "Ὁ μὲν ἄρτος ἡδύ, τὸ δὲ φενακίζειν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.2",
      "text": "προσόν ἔμβαμμα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
