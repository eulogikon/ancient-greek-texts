      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3",
      "text": "Ἄχθομαι δ’ ἀπολωλεκώς ἀλεκτρυόνα τίκτουσαν ᾠὰ πάγκαλα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 4.1",
      "text": "Μᾶζαι, πλακοῦντες, ἰσχάδες",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 4.2",
      "text": "Τιθράσιαι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 5.1",
      "text": "Χλαῖναν δέ σοι λαβὼν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 5.2",
      "text": "παχεῖαν ἐπιβαλῶ Λακωνικήν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.1",
      "text": "Καὶ στῆτ’ ἐφεξῆς κεστρέων νῆστις",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.2",
      "text": "χορός λαχάνοισιν ὥσπερ χῆνες ἐξενισμένοι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.1",
      "text": "Ἓν γάρ ἐστιν οὐδὲ ἕν, τὰ δὲ δύο μόλις ἕν ἐστιν, ὥς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.2",
      "text": "φησιν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.3",
      "text": "Πλάτων.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.1",
      "text": "Φέρε σὺ τὰ καταχύσματα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.2",
      "text": "ταχέως κατάχει",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.3",
      "text": "τοῦ νυμφίου καὶ τῆς κόρης.",
