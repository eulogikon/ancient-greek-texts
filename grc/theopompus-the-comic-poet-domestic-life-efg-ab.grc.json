      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.3",
      "text": "τηνδὶ λαβοῦσα καὶ τοδί τὸ πουλυπόδειον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.1",
      "text": "Ἡμᾶς δ’ ἀπαλλαχθέντας ἐπ’ ἀγαθαῖς τύχαις ὀβελισκολυχνίου καὶ ξιφομαχαίρας",
      "witness_prefix": "",
