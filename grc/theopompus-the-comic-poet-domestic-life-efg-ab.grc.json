    {
      "kind": "text",
      "reference": "book 2.3",
      "text": "τρέφει γυναῖκα;",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3",
      "text": "Ἡ Θρασυμάχου δ’ ὑμῶν γυνὴ καλῶς ἐπιστατήσει.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.1",
      "text": "Παῦσαι κυβεύων, μειράκιον, καὶ τοῖς βλίτοις διαχρῶ τὸ λοιπόν· κοιλίαν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.2",
      "text": "σκληρὰν ἔχεις, τὰ πετραῖα τῶν ἰχθυδίων ἀπέσθιε· ἡ τρὺξ ἄριστόν ἐστιν εἰς εὐβουλίαν.[ln_5]ταῦτ’ ἢν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.3",
      "text": "ποιῇς, ῥᾴων ἔσει τὴν οὐσίαν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1",
      "text": "Τὸν δὲ Μύσιον Ἀκέστορ’ ἀναπέπεικεν ἀκολουθεῖν ἅμα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.1",
      "text": "Ἀλλ’ ἡ μὲν Εἰλείθυια",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.2",
      "text": "συγγνώμην ἔχει ὑπὸ τῶν γυναικῶν οὖσα καταπλὴξ τὴν τέχνην.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.1",
      "text": "Ὥς μοι δοκεῖν εἶναι τὸ πρόθυρον",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.2",
      "text": "τοῦτο βασανιστήριον, τὴν δ’ οἰκίαν ζήτρειον ἢ κακὸν μέγα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2",
      "text": "Ἐπίνομεν μετὰ ταῦτα * * * * * κατακείμενοι μαλακώτατ’ ἐπὶ τρικλινίῳ Τελαμῶνος οἰμώζοντες ἀλλήλοις μέλη.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3",
      "text": "Τρώγουσι μύρτα καὶ πέπονα μιμαίκυλα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 4",
      "text": "Κἄπειτ’ ἰδὼν ἀσφάραγον ἐν θάμνῳ τινί.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 5.1",
      "text": "Μαλθακωτέρα πέπονος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 5.2",
      "text": "σικυοῦ μοι γέγονε.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 6.1",
      "text": "Δεσπότου",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 6.2",
      "text": "πενέστου ῥυσὰ βουλευτήρια.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 7.1",
      "text": "Δὶς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 7.2",
      "text": "παῖδες οἱ γέροντες ὀρθῷ τῷ λόγῳ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 8",
      "text": "[spk_β]Εἴσω δραμὼν αἴτησον. Β. ἀλλ’ οὐκ ἐκφορά.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 9",
      "text": "Ἄπνους ἄνευρος ἀσθενὴς ἀνέντατος.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 10.1",
      "text": "Ἀλλ’ εἰ δοκεῖ, χρὴ ταῦτα δρᾶν· εὐοδεῖν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 10.2",
      "text": "πορεύομαι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 11",
      "text": "Αἱμασιολογεῖν ἄριστ’ ἠπίστατο.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 12",
      "text": "Ἄφωνος ἐγένετο, ἔπειτα μέντοι πάλιν ἀνηνέχθη.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 13.1",
      "text": "τοὺς Ἕλληνας ἥδιστον",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 13.2",
      "text": "ποτόν ἐλευθερίας γεύσαντες ὄξος ἐνέχεαν,",
      "witness_prefix": "",
      "speaker": null
    }
  ],
