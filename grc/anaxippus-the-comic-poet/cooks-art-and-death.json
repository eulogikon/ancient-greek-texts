      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.13",
      "text": "τραπέζης καὶ σίαλον ἀπήγαγον, τῶν τ’ ἐσθιόντων ἀνεκάθηραν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.14",
      "text": "τοὺς πόρους. ὁ μὲν οὖν Ῥόδιος",
