    {
      "kind": "text",
      "reference": "book 314-23.2",
      "text": "ποιηματα βαρβαρικα· μηδικ περσ[ικα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 316",
      "text": "[ln_1]ἥγεό μοι λόγον ἄλλον, ὅπως Ἀσίης ἀπὸ γαίης ἦλθεν ἐς Εὐρώπην πόλεμος μέγας",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 317.1",
      "text": "[ln_1]ἆ μάκαρ, ὅστις ἔην κεῖνον",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 317.2",
      "text": "χρόνον ἴδρις ἀοιδῆς, Μουσάων θεράπων, ὅτ’ ἀκήρατος ἦν ἔτι λειμών· νῦν δ’ ὅτε πάντα δέδασται, ἔχουσι δὲ πείρατα τέχναι, ὕστατοι ὥστε δρόμου καταλειπόμεθ’, οὐδέ πῃ ἔστι[ln_5]πάντῃ παπταίνοντα νεοζυγὲς ἅρμα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 317.3",
      "text": "πελάσσαι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 318.1",
      "text": "ἐν α τῶν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 318.2",
      "text": "Περσικῶν[ln_1]περὶ δὲ κρήνας ἀρεθούσας μυρία φῦλ’ ἐδονεῖτο",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 318.3",
      "text": "πολυσμήνοισι μελίσσαις 〈εἴκελα〉",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 319.1",
      "text": "μηλονόμοι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 319.2",
      "text": "τε Σάκαι, γενεᾷ Σκύθαι· αὐτὰρ ἔναιον Ἀσίδα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 319.3",
      "text": "πυροφόρον· νομάδων γε μὲν ἦσαν ἄποικοι, ἀνθρώπων νομίμων.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 320.1",
      "text": "τῶν δ’ ὄπιθεν διέβαινε γένος θαυμαστὸν ἰδέσθαι, γλῶσσαν μὲν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 320.2",
      "text": "Φοίνισσαν ἀπὸ στομάτων ἀφιέντες, ᾤκεον δ’ ἐν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 320.3",
      "text": "Σολύμοις ὄρεσι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 320.4",
      "text": "πλατέῃ παρὰ λίμνῃ, αὐχμαλέοι κορυφάς, τροχοκουράδες, αὐτὰρ ὕπερθεν[ln_5]ἵππων δαρτὰ πρόσωπ’ ἐφόρευν ἐσκληκότα καπνῷ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 322.1",
      "text": "νηῦς δέ τις ὠκύπορος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 322.2",
      "text": "Σαμίη",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 322.3",
      "text": "συὸς εἶδος ἔχουσα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 323.1",
      "text": "ὅρκον δ’ οὔτ’ ἄδικον",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 323.2",
      "text": "χρεὼν ἔμμεναι οὔτε δίκαιον",
      "witness_prefix": "",
      "speaker": null
    }
