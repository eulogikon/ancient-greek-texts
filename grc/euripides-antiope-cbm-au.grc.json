    {
      "kind": "text",
      "reference": "unknown",
      "text": "γυναικομίμωι διαπρέπεις μορφώματι κοὔτ’ ἂν δίκης βουλαῖσι προσθεῖ’ ἂν λόγον,",
      "witness_prefix": "",
      "speaker": null
