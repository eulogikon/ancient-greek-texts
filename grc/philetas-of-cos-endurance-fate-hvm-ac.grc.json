      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 6.2",
      "text": "τις ἐναντίον ἦλθεν ὁδίτης.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 7.1",
      "text": "Ἦ μὲν γὰρ",
