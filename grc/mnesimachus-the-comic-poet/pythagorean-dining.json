      "kind": "text",
      "reference": "book 1.1",
      "text": "Εἰμὶ γὰρ Βοιώτιος, ὀλίγα μὲν ἄλλων δίκαια",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
