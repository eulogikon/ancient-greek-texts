    {
      "kind": "text",
      "reference": "book 1.3",
      "text": "τραγήμαθ’ ἧκε, πυραμοῦς, ἄμης, ᾠῶν ἑκατόμβη. πάντα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.4",
      "text": "ταῦτ’ ἐχναύομεν.[ln_5]ἐμασώμεθ’ οὕτως ἀνδρικῶς ὅς’ εἴχομεν· καὶ γὰρ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
