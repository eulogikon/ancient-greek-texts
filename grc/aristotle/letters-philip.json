      "kind": "text",
      "reference": "Ep t",
      "text": "ΑΡΙΣΤΟΤΕΛΟΥΣ ΕΠΙΣΤΟΛΑΙ. Φιλίππῳ.",
      "witness_prefix": "",
      "speaker": null
