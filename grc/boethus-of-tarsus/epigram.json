  "research_html": "<div class=\"research-section\">\n<p class=\"research-text\">The epigram attributed to Boethus of Tarsus is a lost work. No text, specific subject matter, or individual lines from it are recorded in surviving sources. It is not attested in any manuscript tradition or anthology, such as the Greek Anthology. The work is considered lost, with its attribution and any reported structure relying on unverified secondary references. Boethus of Tarsus was a Greek poet from Cilicia who wrote both epic poetry and epigrams, but his floruit remains uncertain. The complete loss of his epigrammatic output limits his significance to that of a minor figure in Hellenistic poetry with no documented later influence.</p>\n</div>",
  "rows": [
    {
      "kind": "text",
      "reference": "book 248.1.1",
      "text": "Εἰ τοῖος Διόνυσος ἐς ἱερὸν ἦλθεν Ὄλυμπον",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 248.1.2",
      "text": "κωμάζων Λήναις σύν ποτε καὶ Σατύροις,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 248.1.3",
      "text": "οἷον ὁ τεχνήεις Πυλάδης ὠρχήσατο κεῖνον",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 248.1.4",
      "text": "ὀρθὰ κατὰ τραγικῶν τέθμια μουσοπόλων,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 248.5",
      "text": "παυσαμένη ζήλου Διὸς ἂν φάτο σύγγαμος Ἥρη·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 248",
      "text": "„Ἐψεύσω, Σεμέλη, Βάκχον· ἐγὼ δ’ ἔτεκον.“",
      "witness_prefix": "",
      "speaker": null
    }
  ],
