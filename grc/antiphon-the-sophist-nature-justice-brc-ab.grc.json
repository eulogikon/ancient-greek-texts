      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 19.4",
      "text": "πρὸς τὸ φῶς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 19.5",
      "text": "παρεγγυῶμεν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 19.6",
      "text": "τοῖς ἐπιγιγνομένοις ἑτέροις (Stobaei Flor., XCVIII, 63).",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 20.1",
      "text": "Πρῶτον οἶμαι τῶν ἐν ἀνθρώποις ἐστὶ παίδευσις· ὅταν γάρ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 20.2",
