  "research_html": "<div class=\"research-section\">\n<p class=\"research-text\">Archimelus was a Hellenistic Greek epigrammatist active in the 3rd century BCE, most notably at the court of Ptolemy II Philadelphus in Alexandria. His work survives exclusively within the manuscript tradition of the Greek Anthology, appearing across several of its thematic books, including those dedicated to dedicatory, sepulchral, and epideictic poetry. The poems attributed to him encompass traditional epigrammatic genres, featuring encomiastic verses praising the Ptolemaic ruler, descriptive pieces on votive offerings, and epitaphs for both historical and contemporary figures. One of his most significant surviving epigrams offers an ekphrastic description of Lysippus’s famous statue of Opportunity, or Kairos, serving as an important literary testimony for this lost work of sculpture. His refined verses represent the artistic development of the epigram form during the Alexandrian period and function as valuable historical documents of courtly culture and royal ideology.</p>\n</div>",
  "rows": [
    {
      "kind": "text",
      "reference": "book 50.1.1",
      "text": "Τὴν Εὐριπίδεω μήτ’ ἔρχεο μήτ’ ἐπιβάλλου",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 50.1.2",
      "text": "δύσβατον ἀνθρώποις οἶμον, ἀοιδοθέτα·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 50.1.3",
      "text": "λείη μὲν γὰρ ἰδεῖν καὶ ἐπίκροτος· ἢν δέ τις αὐτὴν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 50.1.4",
      "text": "εἰσβαίνῃ, χαλεποῦ τρηχυτέρη σκόλοπος·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 50.5",
      "text": "ἢν δὲ τὰ Μηδείης Αἰητίδος ἄκρα χαράξῃς,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 50",
      "text": "ἀμνήμων κείσῃ νέρθεν. ἔα στεφάνους.",
      "witness_prefix": "",
      "speaker": null
    }
  ],
