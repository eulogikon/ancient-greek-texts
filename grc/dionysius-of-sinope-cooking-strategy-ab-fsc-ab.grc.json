    {
      "kind": "text",
      "reference": "book 1.1",
      "text": "Σφόδρα μοι κεχάρισαι, Σιμία, νὴ τοὺς θεοὺς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.2",
      "text": "ταυτὶ προείπας· τὸν μάγειρον εἰδέναι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.3",
      "text": "πολὺ δεῖ γὰρ ἀεὶ πρότερον οἷς μέλλει",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.4",
      "text": "ποιεῖν τὸ δεῖπνον ἢ τὸ δεῖπνον ἐγχειρεῖν",
