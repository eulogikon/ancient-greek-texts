    },
    {
      "kind": "text",
      "reference": "book 1.7",
      "text": "τοῦτ’ ἐπιβλέψῃ μόνον, τοὔψον",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.8",
      "text": "ποιῆσαι κατὰ τρόπον πῶς δεῖ, τίνα",
      "witness_prefix": "",
