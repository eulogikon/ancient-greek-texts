      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.3",
      "text": "παῦρα κακῶς ἔτ͜εα͜.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 4",
      "text": "πάμπαν δ’ ἄμωμος οὔ τις οὐδ’ ἀκήριος.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 5.1",
      "text": "ἄθηλος ἵππωι πῶλος ὣς ἅμα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 5.2",
