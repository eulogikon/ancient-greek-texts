  "rows": [
    {
      "kind": "text",
      "reference": "1",
      "text": "Βίος Ὀππιανοῦ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "2",
      "text": "Ὀππιανὸς ὁ ποιητὴς πατρὸς μὲν ἦν Ἀγησιλάου, μητρὸς δὲ Ζηνοδότης, τὸ δὲ γένος ἀπ’ Ἀναζάρβου τῆς Κιλικίας. ὁ δὲ τούτου πατὴρ τά τ’ ἄλλα πλούσιος ὢν καὶ τῶν ἐν τῇ πολιτείᾳ τῆς πατρίδος αὐτοῦ πρῶτος νενομισμένος, παιδείᾳ δὲ διαπρέπων καὶ φιλόσοφον βίον ζῶν, ἐν τοῖς αὐτοῖς ἤσκησε τὸν υἱὸν παιδεύσας τὴν ἐγκύκλιον ἅπασαν παίδευσιν, μουσικήν τε καὶ γεωμετρίαν, μάλιστα δὲ καὶ γραμματικήν. ἤδη δὲ καὶ Ὀππιανοῦ περὶ λʹ ἔτη γεγονότος ἐπεδήμησε τῇ Ἀναζάρβῳ Σεβῆρος ὁ Ῥωμαίων βασιλεύς. ἐπειδὴ δὲ πάντας τοὺς πολιτευομένους ἀπαντᾶν ἔδει τῷ βασιλεῖ, ἀμελήσαντα τῆς ἀπαντήσεως Ἀγησίλαον, ὡς δὴ φιλοσόφως ζῶντα καὶ κενοδοξίας καταφρονοῦντα, χαλεπήνας ὁ βασιλεὺς ἐξώρισεν εἰς Μελίτην νῆσον τοῦ Ἀδρίου. οὗ δὴ συνὼν ὁ ποιητὴς τῷ πατρὶ ἔγραψε ταῦτα τὰ ποιήματα ἀξιολογώτατα ὄντα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "3",
      "text": "ἐλθὼν δ’ εἰς Ῥώμην ἐπ’ Ἀντωνίνου τοῦ υἱοῦ Σεβήρου καὶ παρεξελθὼν αὐτὰ (ὁ γὰρ Σεβῆρος ἐτεθνήκει), ἠξιώθη αἰτεῖν ὃ ἂν βούλοιτο· ὁ δὲ κάθοδον τῷ πατρὶ ᾔτησεν, ἧς καὶ ἔτυχεν. ἔλαβε δὲ καὶ ἐπὶ ἑκάστῳ ἔπει ἤτοι στίχῳ χρυσοῦν νόμισμα. ἐπανελθὼν δ’ ἅμα τῷ πατρὶ λοιμοῦ ἐπελθόντος τῇ Ἀναζάρβῳ μετ’ ὀλίγον χρόνον τελευτᾶ. οἱ δὲ πολῖται θάψαντες αὐτὸν ἄγαλμα πολυτελὲς αὐτῷ ἀνέστησαν καὶ τάδ’ ἐνεχάραξαν· Ὀππιανὸς κλέος εἷλον ἀείδιον, ἀλλά με Μοίρης βάσκανος ἐξήρπαξε μίτος, κρυερός τ’ Ἀΐδης με καὶ νέον ὄντα κατέσχε, τὸν εὐεπίης ὑποφήτην.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "4",
      "text": "εἰ δὲ πολύν με χρόνον ζωὸν μίμνειν φθόνος αἰνὸς εἴας’, οὐκ ἄν τίς μοι ἴσον γέρας ἔλλαχε φωτῶν. ἔγραψε δὲ καὶ ἄλλα ποιήματά τινα, ζήσας ἔτη λʹ. πολὺ δὲ τὸ ἀνθηρὸν ἔχει καὶ λεῖον μετὰ τοῦ πυκνοῦ τε καὶ ἁδροῦ, ὅπερ ἐστὶ δυσχερέστατον. τυγχάνει δὲ μάλιστα ἐν τοῖς γνωμολο γίαις καὶ παραβολαῖς.",
      "witness_prefix": "",
      "speaker": null
    }
  ],
