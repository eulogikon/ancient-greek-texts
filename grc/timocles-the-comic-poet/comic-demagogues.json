      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.6",
      "text": "συγγνώμην ἔχω. Α. ὅ τ’ ἐν λόγοισι δεινὸς Ὑπερείδης ἔχει. Β. τοὺς ἰχθυοπώλας οὗτος ἡμῖν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.7",
