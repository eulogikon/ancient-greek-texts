    {
      "kind": "text",
      "reference": "book 1.7",
      "text": "σκόμβρους ξενίσῃ μεγάλους ἡδομένη.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.1",
      "text": "Ἡ Πυθιονίκη δ’ ἀσμένως",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.2",
      "text": "σε δέξεται, καί σου κατέδεται",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.3",
      "text": "τυχὸν ἴσως ἃ νῦν ἔχεις λαβὼν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.4",
      "text": "παρ’ ἡμῶν δῶρ’· ἄπληστός ἐστι γάρ, ὅμως δὲ δοῦναί σοι κέλευσον",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.5",
      "text": "σαργάνας[ln_5]αὐτήν· ταρίχους εὐπόρως γὰρ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.6",
      "text": "τυγχάνει ἔχουσα καὶ σύνεστι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.7",
      "text": "σαπέρδαις δυσίν, καὶ ταῦτ’ ἀνάλτοις καὶ πλατυρρύγχοις",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.8",
      "text": "τισίν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.1",
      "text": "Τόν τ’ ἰχθυόρρουν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.2",
      "text": "ποταμὸν Ὑπερείδην πέρα, ὃς ἠπίαις",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.3",
      "text": "φωναῖσιν ἔμφρονος λόγου κόμποις",
