    },
    {
      "kind": "text",
      "reference": "book 1.1",
      "text": "Οἴμοι κακοδαίμων, ὡς ἐρῶ. μὰ τοὺς θεούς, Τιθύμαλλος οὐδεπώποτ’ ἠράσθη",
      "witness_prefix": "",
