  "research_html": "<div class=\"research-section\">\n<p class=\"research-text\">The work is a Greek verse inscription authored by Isyllus of Epidaurus around 280 BCE. Carved on stone at the sanctuary of Asclepius in Epidaurus, it is a single, coherent poem of 81 lines that blends personal narrative, cult myth, and sacred law. The text begins with Isyllus recounting a personal vision in which the god Asclepius commands him to establish a new ritual procession. It then provides a foundational myth for the god’s birth and arrival in Epidaurus, prescribes detailed regulations for a children’s procession to the temple, and concludes with political praise linking good governance to piety, followed by a final hymn. The poem survives completely in its original inscribed form, not through medieval manuscripts. Its structure primarily uses dactylic hexameter but switches to elegiac couplets for a central section. Modern scholars interpret the work as a public monument designed to reform and elevate local cult practice while also engaging with the political realities of the early Hellenistic period. It is thought to have been written to secure divine and royal favor, reinforcing the sanctuary’s importance and the author’s own role in civic religious life.</p>\n</div>",
  "rows": [
    {
      "kind": "text",
      "reference": "unit_1.1",
      "text": "Ἴσυλλος Σωκράτευς Ἐπιδαύριος ἀνέθηκε",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "unit_1.2",
      "text": "Ἀπόλλωνι Μαλεάται καὶ Ἀσκλαπιῶι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "unit_1.3",
      "text": "A Δᾶμος εἰς ἀριστοκρατίαν ἄνδρας αἰ προάγοι καλῶς,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "unit_1.4",
      "text": "αὐτὸς ἰσχυρότερος· ὀρθοῦται γὰρ ἐξ ἀνδραγαθίας.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "5.1",
      "text": "Αἰ δέ τις καλῶς προαχθεὶς θιγγάνοι πονηρίας",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "5.2",
      "text": "πάλιν ἐπαγκρούων, κολάζων δᾶμος ἀσφαλέστερος.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "5.3",
      "text": "Τάνδε τὰν γνώμαν τόκ’ ἦχον καὶ ἔλεγον καὶ νῦν λέγω.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "5.4",
      "text": "Εὐξάμαν ἀνγράψεν, αἴ κ’ εἰς τάνδε τὰν γνώμαν πέτη",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "5.5",
      "text": "ὁ νόμος ἀμὶν ὃν ἐπέδειξα· ἔγεντο δ’, οὐκ ἄνευ θεῶν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "10.1",
      "text": "B Τόνδ’ ἱαρὸν θείαι μοίραι νόμον ηὗρεν Ἴσυλλος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "10.2",
      "text": "ἄφθιτον ἀέναον γέρας ἀθανάτοισι θεοῖσιν,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "10.3",
      "text": "καί νιν ἅπας δᾶμος θεθμὸν θέτο πατρίδος ἀμᾶς,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "10.4",
      "text": "χεῖρας ἀνασχόντες μακάρεσσιν ἐς οὐρανὸν εὐρύ[ν·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "10.5",
      "text": "οἵ κεν ἀριστεύωσι πόληος τᾶσδ’ Ἐπιδαύρου",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "15.1",
      "text": "λέξασθαί τ’ ἄνδρας καὶ ἐπαγγεῖλαι κατὰ φυλὰς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "15.2",
      "text": "οἷς πολιοῦχος ὑπὸ στέρνοις ἀρετά τε καὶ αἰδώς,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "15.3",
      "text": "τοῖσιν ἐπαγγέλλεν καὶ πομπεύεν σφε κομῶντας",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "15.4",
      "text": "Φοίβωι ἄνακτι υἱῶι τ’ Ἀσκλαπιῶι ἰατῆρι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "15.5",
      "text": "εἵμασιν ἐν λευκοῖσι δάφνας στεφάνοις ποτ’ Ἀπόλλω,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "20.1",
      "text": "ποὶ δ’ Ἀσκλαπιὸν ἔρνεσι ἐλαίας ἡμεροφύλλου",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "20.2",
      "text": "ἁγνῶς πομπεύειν, καὶ ἐπεύχεσθαι πολιάταις",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "20.3",
      "text": "πᾶσιν ἀεὶ διδόμεν τέκνοις τ’ ἐρατὰν ὑγίειαν,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "20.4",
      "text": "εὐνομίαν τε καὶ εἰράναν καὶ πλοῦτον ἀμεμφῆ,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "20.5",
      "text": "τὰν καλοκαγαθίαν τ’ Ἐπιδαυροῖ ἀεὶ ῥέπεν ἀνδρῶν,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "25.1",
      "text": "ὥραις ἐξ ὡρᾶν νόμον ἀεὶ τόνδε σέβοντας·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "25.2",
      "text": "οὕτω τοί κ’ ἀμῶν περιφείδοιτ’ εὐρύοπα Ζεύς.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "25.3",
      "text": "C Πρῶτος Μᾶλος ἔτευξεν Ἀπόλλωνος Μαλεάτα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "25.4",
      "text": "βωμὸν καὶ θυσίαις ἠγλάισεν τέμενος.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "25.5",
      "text": "Οὐδέ κε Θεσσαλίας ἐν Τρίκκηι πειραθείης",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "30.1",
      "text": "εἰς ἄδυτον καταβὰς Ἀσκληπιοῦ, εἰ μὴ ἀφ’ ἁγνοῦ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "30.2",
      "text": "πρῶτον Ἀπόλλωνος βωμοῦ θύσαις Μαλεάτα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "30.3",
      "text": "D Ἴσυλλος Ἀστυλαίδαι ἐπέθηκε μαντεύσασθα[ί] οἱ περὶ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "30.4",
      "text": "τοῦ παιᾶνος ἐν Δελφοῖς, ὃν ἐπόησε εἰς τὸν Ἀπόλλωνα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "30.5",
      "text": "καὶ τὸν Ἀσκληπιόν, ἦ λώιόν οἵ κα εἴη ἀγγράφοντι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "35.1",
      "text": "τὸν παιᾶνα. Ἐμάντευσε λώιόν οἵ κα εἶμεν ἀγγράφοντι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "35.2",
      "text": "καὶ αὐτίκα καὶ εἰς τὸν ὕστερον χρόνον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "36.1",
      "text": "PAEAN",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "36.2",
      "text": "E Ἰὲ Παιᾶνα θεὸν ἀείσατε λαοί,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "36.3",
      "text": "ζαθέας ἐνναέτα[ι] τᾶσδ’ Ἐπιδαύρου.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "36.4",
      "text": "Ὧδε γὰρ φάτις ἐνέπους’ ἤλυθ’ ἐς ἀκοὰς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "40.1",
      "text": "προγόνων ἀμετέρων, ὦ Φοῖβ’ Ἀπόλλων.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "40.2",
      "text": "Ἐρατὼ Μοῦσαν πατὴρ Ζεὺς λέγεται Μά‐",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "40.3",
      "text": "λ[ωι] δόμεν παράκοιτιν ὁσίοισι γάμοις. Φλεγύας δ’, [ὃς] πατρίδ’ Ἐπίδαυρον ἔναιεν,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "40.4",
      "text": "θυγατέρα Μάλου γαμεῖ, τὰν Ἐρατὼ γεί‐",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "45.1",
      "text": "νατο μάτηρ, Κλεοφήμα δ’ ὀνομάσθη.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "45.2",
      "text": "Ἐγ δὲ Φλεγύα γένετο, Αἴγλα δ’ ὀνομάσθη·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "45.3",
      "text": "τόδ’ ἐπώνυμον· τὸ κάλλος δὲ Κορωνὶς ἐπεκλήθη.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "45.4",
      "text": "Κατιδὼν δ’ ὁ χρυσότοξος Φοῖβος ἐμ Μά‐",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "45.5",
      "text": "λου δόμοις παρθενίαν ὥραν ἔλυσε, λεχέων δ’ ἱμεροέντων ἐπέβας, Λα‐",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "45.6",
      "text": "τῶιε κόρε χρυσοκόμα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "45.7",
      "text": "Σέβομαί σε· ἐν δὲ θυώδει τεμένει τέκε‐",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "45.8",
      "text": "το ἶνιν Αἴγλα, γονίμαν δ’ ἔλυσεν ὠδῖ‐",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "45.9",
      "text": "να Διὸς παῖς μετὰ Μοιρᾶν Λάχεσίς τε μαῖ’ ἀγαυά·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "55.1",
      "text": "ἐπίκλησιν δέ νιν Αἴγλας ματρὸς Ἀσκλα‐",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "55.2",
      "text": "πιὸν ὠνόμαξε Ἀπόλλων, τὸν νόσων παύ‐",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "55.3",
      "text": "[σ]τορα, δωτῆρ’ ὑγιείας, μέγα δώρημα βροτοῖς.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "55.4",
      "text": "Ἰὲ Παιάν, ἰὲ Παιάν, χαῖρεν Ἀσκλα‐",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "55.5",
      "text": "πιέ, τὰν σὰν Ἐπίδαυρον ματρόπολιν αὔ‐",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "60.1",
      "text": "ξων, ἐναργῆ δ’ ὑγίειαν ἐπιπέμποις",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "60.2",
      "text": "φρεσὶ καὶ σώμασιν ἀμοῖς, ἰὲ Παιάν, ἰὲ Παιάν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "60.3",
      "text": "F Καὶ τόδε σῆς ἀρετῆς, Ἀσκληπιέ, [τ]οὖργον ἔδειξας",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "60.4",
      "text": "ἐγ κείνοισι χρόνοις ὅκα δὴ στρατὸν ἦγε Φίλιππος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "60.5",
      "text": "εἰς Σπάρτην, ἐθέλων ἀνελεῖν βασιληΐδα τιμήν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "65.1",
      "text": "Τοῖς δ’ Ἀσκληπιὸς [ἦ]λθε βοαθόος ἐξ Ἐπιδαύρου",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "65.2",
      "text": "τιμῶν Ἡρακλέος γενεάν· ἇς φείδετο ἄρα Ζεύς.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "65.3",
      "text": "Τουτάκι δ’ ἦλθε, ὅχ’ ὁ παῖς ἐκ Βουσπόρου ἦλθεν κάμνω[ν],",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "65.4",
      "text": "τῶι τύγα ποστείχοντι συνάντησας σὺν ὅπλοισιν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "65.5",
      "text": "λαμπόμενος χρυσέοις, Ἀσκλαπιέ· παῖς δ’ ἐσιδών σε",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "70.1",
      "text": "λίσσετο χεῖρ’ ὀρέγων ἱκέτηι μύθωι σε προσαντῶν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "70.2",
      "text": "“Ἄμμορός εἰμι τεῶν δώρων, Ἀσκλαπιὲ Παιάν,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "70.3",
      "text": "ἀλλά μ’ ἐποίκτειρον”. Τὺ δέ μοι τάδ’ ἔλεξας ἐναργῆ·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "70.4",
      "text": "“Θάρσει· καιρῶι γάρ σοι ἀφίξομαι, ἀλλὰ μέν’ αὐτεῖ,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "70.5",
      "text": "τοῖς Λακεδαιμονίοις χαλεπὰς ἀπὸ κῆρας ἐρύξας,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "75.1",
      "text": "οὕνεκα τοὺς Φοίβου χρησμοὺς σώζοντι δικαίως",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "75.2",
      "text": "οὓς μαντευσάμενος παρέταξε πόληι Λυκοῦργος”.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "75.3",
      "text": "Ὣς ὃ μὲν ὤιχετο ἐπὶ Σπάρτην· ἐμὲ δ’ ὦρσε νόημα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "75.4",
      "text": "ἀγγεῖλαι Λαχεδαιμονίοις ἐλθόντα τὸ θεῖον πάντα μάλ’ ἑξείας· οἳ δ’ αὐδήσαντος ἄκουσαν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "80.1",
      "text": "σώτειραν φήμαν, Ἀσκλαπιέ, καί σφε σάωσας.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "80.2",
      "text": "Οἳ δὴ ἐκάρυξαν πάντας ξενίαις σε δέκεσθαι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "80.3",
      "text": "σωτῆρα εὐρυχόρου Λακεδαίμονος ἀγκαλέοντες.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "80.4",
      "text": "Ταῦτα τοί, ὦ μέγ’ ἄριστε θεῶν, ἀνέθηκεν Ἴσυλλος τι[μ]ῶν σὴν ἀρετήν, ὦναξ, ὥσπερ τὸ δίκαιον.",
      "witness_prefix": "",
      "speaker": null
    }
  ],
