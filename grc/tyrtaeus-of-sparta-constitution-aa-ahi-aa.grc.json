    {
      "kind": "text",
      "reference": "book 5.2",
      "text": "πατέρες· εἰκοστῶι δ’ οἱ μὲν κατὰ πίονα ἔργα λιπόντες",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 5.3",
      "text": "φεῦγον Ἰθωμαίων ἐκ μεγάλων ὀρέων.",
