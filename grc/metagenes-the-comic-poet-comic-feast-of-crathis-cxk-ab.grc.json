      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.2",
      "text": "πρῶτον, κἄπειτά με πάντ’ ἐπε‐[ln_1]ρώτα, ὅ τι ἂν βούλῃ· νῦν γὰρ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.3",
      "text": "πεινῶν δεινῶς πώς εἰμ’ ἐπιλήσμων.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 4.1",
      "text": "Ἱερεὺς γὰρ ὢν",
