  "research_html": "<div class=\"research-section\">\n<p class=\"research-text\">The <strong>Epigrams</strong> of Hedylus of Samos constitute a collection of twenty-four short poems by the Hellenistic poet, who was active in the early third century BCE. Composed in a literary Greek dialect, these verses exemplify the sophisticated, bookish form the epigram had attained, having evolved from its origins as simple stone inscriptions into a refined literary genre. The poems engage with characteristic Hellenistic themes, including symposiastic celebrations of wine and banquets, light-hearted erotic subjects, and dedicatory verses. A notable epigram praises a large ceremonial cup belonging to Ptolemy II Philadelphus, a detail that firmly links Hedylus to the intellectual and artistic milieu of Alexandria. No independent manuscript of his work survives; the extant collection is fragmentary and known exclusively through later quotations. These twenty-four epigrams have been recovered by modern scholars from major ancient anthologies, principally the <strong>Greek Anthology</strong>. This mode of transmission means his poetry is mediated through the selective filters of later editors. Scholars interpret his work as a product of Alexandrian court culture, reflecting the learned, polished, and often playful aesthetic championed by contemporary poets such as Callimachus, with whom Hedylus was associated.</p>\n</div>",
  "rows": [
    {
      "kind": "text",
      "reference": "book 161.1.1",
      "text": "Εὐφρὼ καὶ Θαῒς καὶ Βοίδιον, αἱ Διομήδους,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 161.1.2",
      "text": "Γραῖαι, ναυκλήρων ὁλκάδες εἰκόσοροι,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 161.1.3",
      "text": "Ἆγιν καὶ Κλεοφῶντα καὶ Ἀνταγόρην, ἕν’ ἑκάστη,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 161.1.4",
      "text": "γυμνούς, ναυηγῶν ἥσσονας, ἐξέβαλον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 161.5.1",
      "text": "ἀλλὰ σὺν αὐταῖς νηυσὶ τὰ λῃστρικὰ τῆς Ἀφροδίτης",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 161.5.2",
      "text": "φεύγετε· Σειρήνων αἵδε γὰρ ἐχθρότεραι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 199.1.1",
      "text": "Οἶνος καὶ προπόσεις κατεκοίμισαν Ἀγλαονίκην",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 199.1.2",
      "text": "αἱ δόλιαι καὶ ἔρως ἡδὺς ὁ Νικαγόρεω,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 199.1.3",
      "text": "ἧς πάρα Κύπριδι ταῦτα μύροις ἔτι πάντα μυδῶντα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 199.1.4",
      "text": "κεῖνται παρθενίων ὑγρὰ λάφυρα πόθων,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 199.5.1",
      "text": "σάνδαλα καὶ μαλακαί, μαστῶν ἐνδύματα, μίτραι,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 199.5.2",
      "text": "ὕπνου καὶ σκυλμῶν τῶν τότε μαρτύρια.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 292.1.1",
      "text": "Αἱ μίτραι τό θ’ ἁλουργὲς ὑπένδυμα τοί τε Λάκωνες",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 292.1.2",
      "text": "πέπλοι καὶ ληρῶν οἱ χρύσεοι κάλαμοι,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 292.1.3",
      "text": "πάνθ’ ἅμα Νικονόῃ συνεπήιεν· ἦν γὰρ Ἐρώτων",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 292.1.4",
      "text": "καὶ Χαρίτων ἡ παῖς ἀμβρόσιόν τι θάλος.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 292.5.1",
      "text": "τοιγὰρ τῷ κρίναντι τὰ καλλιστεῖα Πριάπῳ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 292.5.2",
      "text": "νεβρίδα καὶ χρυσέην τήνδ’ ἔθετο προχόην.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 123.1.1",
      "text": "Ἆγις Ἀρισταγόρην οὔτ’ ἔκλυσεν οὔτ’ ἔθιγ’ αὐτοῦ·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 123.1.2",
      "text": "ἀλλ’ ὅσον εἰσῆλθεν, κᾤχετ’ Ἀρισταγόρης.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 123.1.3",
      "text": "ποῦ τοίην ἀκόνιτος ἔχει φύσιν; ὦ σοροπηγοί,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 123",
      "text": "Ἆγιν καὶ μίτραις βάλλετε καὶ στεφάνοις.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 414.1",
      "text": "Λυσιμελοῦς Βάκχου καὶ λυσιμελοῦς Ἀφροδίτης",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 414",
      "text": "γεννᾶται θυγάτηρ λυσιμελὴς ποδάγρα.",
      "witness_prefix": "",
      "speaker": null
    }
  ],
