      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 59.3",
      "text": "χαλκοῦν κλέψας ἀπορῶν κεῖται, κοτύλη δ’ ἀνὰ χοίνικα μάττει.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 60",
      "text": "[spk_β]γαλῆν ὁρῶ. Β. ποῖ, πρὸς θεῶν, ποῖ ποῖ γαλῆν;",
