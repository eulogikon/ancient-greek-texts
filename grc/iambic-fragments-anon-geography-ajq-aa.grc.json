      "kind": "text",
      "reference": "53",
      "text": "ὁ τὸν κυσὸν τρωθεὶς ἤδη αἰσώπου μάλιστα τοῦ κράνους χρεία.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "54",
      "text": "ζῶιον ἐν πυρὶ σκαῖρον·",
      "witness_prefix": "",
      "speaker": null
