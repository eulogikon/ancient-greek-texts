      "speaker": null
    },
    {
      "kind": "text",
      "reference": "51",
      "text": "ἀνὴρ ὅδ’ 〈 〉 ἑσπέρης καθεύδοντα ἀπ’ ὦν ἔδυσε 〈 〉 χλούνην.",
      "witness_prefix": "",
      "speaker": null
