  "research_html": "<div class=\"research-section\">\n<p class=\"research-text\">The Medical Recipe for Demetrius is a lost didactic poem by Aglaias of Byzantium, a physician from Constantinople. Composed in verse and structured in nineteen passages, the work is a technical prescription addressed to an individual named Demetrius, situating it within the Byzantine tradition of rendering medical material in poetic form for mnemonic and instructional purposes. Its content focused on medical treatment and pharmacology, employing a didactic poetic form and indicating a relationship of patronage through its dedication. The work is known solely from an entry in the tenth-century Byzantine encyclopedia, the Suda, which records its title, author, and format, but no fragments or further description of its medical content survive. As a lost verse recipe, the poem exemplifies the breadth of technical didactic poetry in the Greek tradition and provides evidence for professional medical exchange and patronage in the Byzantine world.</p>\n</div>",
  "rows": [
    {
      "kind": "text",
      "reference": "book 18.1",
      "text": "Ἀγλαΐας τόδε",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 18.2",
      "text": "σοι Βυζάντιος ἐσθλὸν ἰάλλω [para]ἰητὴρ ἑτάρῳ δῶρον ἀοιδοπόλῳ, ὀφθαλμῶν μὲν ἄκος, Δημήτριε, τῶν ὑποχεῖσθαι [para]ἀρχομένων, ὑπ’ ἐμῆς δ’ εὑρεθὲν εὐμογίης.[ln_5]καὶ σοὶ δ’ ἔξοχον ἔσται ἐς ἄχθεα, παντί τ’ ὄνειαρ [para]παρμόνιμον, κάμψῃς ἄχρι κεν ἐς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 18.3",
      "text": "πλέονας. ὅσσα δ’ ἔχει θρόνα λέξαι ἔοικέ μοι, ὡς ἐπαρήγειν [para]χρῄσαντι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 18.4",
      "text": "σθεναρὴ σύνθεσις ἥδε πέλει. ἄνθους μὲν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 18.5",
      "text": "χαλκοῦ πεντώβολον, ἰσοβαρὲς δὲ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 18.1",
      "text": "[ln_10]τοῦ συοδηλήτου τὴν ἐρατὴν γενέτιν. καὶ μεῖον",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 18.2",
      "text": "τούτων ὀβολῷ στρόγγυλμα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 18.3",
      "text": "πυραιθὲς [para]πρόσθες ὃ Καλλατικοῖς ἄλδεται ἐν δαπέδοις. καὶ δύο διδράχμω, τὸ μὲν ἐκ ξανθότριχος ἄνθους, [para]αἴνυσο δ’ ἐκ μηδέων θάτερον ἱπποδάμου,[ln_15]ἡμίσταθμον ὅτου",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 18.4",
      "text": "πατρὸς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 18.5",
      "text": "ψευδωνύμου ἔστω, [para]ὃς γῆμαι δμωῆς υἱέϊ δῶκε κόρην. στῆσον δ’ αὖ †ἀλόϊον ἓν ἥμισυ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 18.6",
      "text": "τοῦ προτέροιο [para]ἄχθος· ἄγε",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 18.7",
      "text": "στάχυος 〈Σ〉ινδογενοῦς ὀβολόν. διστάσιος δ’ αὐτῷ πελέτω λίθος εἰαριήτης,[ln_20]διστάσιον δ’ ἀφροῦ θρύμμα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 18.8",
      "text": "Φακουσιακοῦ. σὺν δὲ τριάκοντα δραχμαῖς ἔτι καὶ δύο μίσγε ὁλκὰς ἐξ ἄνθους νάμασι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 18.9",
      "text": "πηγὸς ἁλός. καὶ †Ζακορίσου Μούσαις ἰσάριθμον ὄπισμα [para]δραχμόθεν ἔστω",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 18.10",
      "text": "σοι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 18.11",
      "text": "συγκατακιρνάμενον[ln_25]τετραμόρου κοτύλης ὃ τιτύσκεται οὐ διὰ χειρῶν [para]ἐν δαπέδοις Ἀκτῆς ἀλλὰ διὰ στομάτων. λεῖα δὲ πάντα καθ’ ἓν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 18.12",
      "text": "τρίψας ἀνάμισγε σὺν ὑγροῖς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 18.1",
      "text": "τημελέως τ’ ἀπόθου",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 18.2",
      "text": "τεῦχος ἐς ἀργύρεον. *",
      "witness_prefix": "",
      "speaker": null
    }
  ],
