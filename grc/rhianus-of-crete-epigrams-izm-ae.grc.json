  "research_html": "<div class=\"research-section\">\n<p class=\"research-text\">The <strong>Epigrams</strong> of Rhianus of Crete are a collection of short poems composed in Greek elegiac verse during the 3rd century BCE. These poems engage with the conventional themes of Hellenistic epigrammatic poetry, including erotic sentiment, votive dedications, and sepulchral epitaphs. Characterized by a clear and polished style, they reflect the refined literary sensibilities of their era. The work survives not as an independent volume but through its preservation within the later compilation known as the <strong>Greek Anthology</strong>, where fifty-eight epigrams are attributed to him. While Rhianus was historically more renowned as an epic poet and a scholarly editor of Homeric texts, his surviving epigrams represent a concise and distinct facet of his literary output, demonstrating the versatility expected of poets writing for a sophisticated, literate audience in the Hellenistic period.</p>\n</div>",
  "rows": [
    {
      "kind": "text",
      "reference": "book 34.1.1",
      "text": "Τὸ ῥόπαλον τῷ Πανὶ καὶ ἰοβόλον Πολύαινος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 34.1.2",
      "text": "τόξον καὶ κάπρου τούσδε καθᾶψε πόδας",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 34.1.3",
      "text": "καὶ ταύταν γωρυτὸν ἐπαυχένιόν τε κυνακτὰν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 34.1.4",
      "text": "θῆκεν ὀρειάρχᾳ δῶρα συαγρεσίης.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 34.5",
      "text": "ἀλλ’, ὦ Πὰν σκοπιῆτα, καὶ εἰς ὀπίσω Πολύαινον",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 34",
      "text": "εὔαγρον πέμποις, υἱέα Σημύλεω.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 173.1.1",
      "text": "Ἀχρυλίς, ἡ Φρυγίη θαλαμηπόλος, ἡ περὶ πεύκας",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 173.1.2",
      "text": "πολλάκι τοὺς ἱεροὺς χευαμένη πλοκάμους,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 173.1.3",
      "text": "γαλλαίῳ Κυβέλης ὀλολύγματι πολλάκι δοῦσα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 173.1.4",
      "text": "τὸν βαρὺν εἰς ἀκοὰς ἦχον ἀπὸ στομάτων,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 173.5.1",
      "text": "τάσδε θεῇ χαίτας περὶ δικλίδι θῆκεν ὀρείῃ,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 173.5.2",
      "text": "θερμὸν ἐπεὶ λύσσης ὧδ’ ἀνέπαυσε πόδα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 278.1.1",
      "text": "Παῖς Ἀσκληπιάδεω καλῷ καλὸν εἵσατο Φοίβῳ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 278.1.2",
      "text": "Γόργος ἀφ’ ἱμερτᾶς τοῦτο γέρας κεφαλᾶς.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 278.1.3",
      "text": "Φοῖβε, σὺ δ’ ἵλαος, Δελφίνιε, κοῦρον ἀέξοις",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 278.1.4",
      "text": "εὔμοιρον λευκὴν ἄχρις ἐφ’ ἡλικίην.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 315.1.1",
      "text": "Τρηχείην κατ’ ἐμεῦ, ψαφαρὴ κόνι, ῥάμνον ἑλίσσοις",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 315.1.2",
      "text": "πάντοθεν ἢ σκολιῆς ἄγρια κῶλα βάτου,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 315.1.3",
      "text": "ὡς ἐπ’ ἐμοὶ μηδ’ ὄρνις ἐν εἴαρι κοῦφον ἐρείδοι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 315.1.4",
      "text": "ἴχνος, ἐρημάζω δ’ ἥσυχα κεκλιμένος.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 315.5.1",
      "text": "ἦ γὰρ ὁ μισάνθρωπος, ὁ μηδ’ ἀστοῖσι φιληθεὶς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 315.5.2",
      "text": "Τίμων οὐδ’ Ἀίδῃ γνήσιός εἰμι νέκυς.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 38.1.1",
      "text": "Ὧραί σοι Χάριτές τε κατὰ γλυκὺ χεῦαν ἔλαιον,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 38.1.2",
      "text": "ὦ πυγά· κνώσσειν δ’ οὐδὲ γέροντας ἐᾷς.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 38.1.3",
      "text": "λέξον μοι, τίνος ἐσσὶ μάκαιρα τὺ καὶ τίνα παίδων",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 38.1.4",
      "text": "κοσμεῖς; ἁ πυγὰ δ’ εἶπε· „Μενεκράτεος.“",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 58.1.1",
      "text": "Ἦ Τροιζὴν ἀγαθὴ κουροτρόφος· οὐκ ἂν ἁμάρτοις",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 58.1.2",
      "text": "αἰνήσας παίδων οὐδὲ τὸν ὑστάτιον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 58.1.3",
      "text": "τόσσον δ’ Ἐμπεδοκλῆς φανερώτερος, ὅσσον ἐν ἄλλοις",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 58",
      "text": "ἄνθεσιν εἰαρινοῖς καλὸν ἔλαμψε ῥόδον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 93.1.1",
      "text": "Οἱ παῖδες λαβύρινθος ἀνέξοδος· ᾗ γὰρ ἂν ὄμμα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 93.1.2",
      "text": "ῥίψῃς, ὡς ἰξῷ τοῦτο προσαμπέχεται.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 93.1.3",
      "text": "τῇ μὲν γὰρ Θεόδωρος ἄγει ποτὶ πίονα σαρκὸς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 93.1.4",
      "text": "ἀκμὴν καὶ γυίων ἄνθος ἀκηράσιον·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 93.5.1",
      "text": "τῇ δὲ Φιλοκλῆος χρύσεον ῥέθος, ὃς τὸ καθ’ ὕψος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 93.5.2",
      "text": "οὐ μέγας, οὐρανίη δ’ ἀμφιτέθηλε χάρις·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 93.5.3",
      "text": "ἢν δ’ ἐπὶ Λεπτίνεω στρέψῃς δέμας, οὐκέτι γυῖα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 93.1",
      "text": "κινήσεις, ἀλύτῳ δ’ ὡς ἀδάμαντι μένεις",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 93.2",
      "text": "ἴχνια κολληθείς· τοῖον σέλας ὄμμασιν αἴθει",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 93.10.1",
      "text": "κοῦρος καὶ νεάτους ἐκ κορυφῆς ὄνυχας.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 93.10.2",
      "text": "χαίρετε, καλοὶ παῖδες, ἐς ἀκμαίην δὲ μόλοιτε",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 93.10.3",
      "text": "ἥβην καὶ λευκὴν ἀμφιέσαισθε κόμην.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 121.1.1",
      "text": "Ἦ ῥά νύ τοι, Κλεόνικε, δι’ ἀτραπιτοῖο κιόντι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 121.1.2",
      "text": "στεινῆς ἤντησαν ταὶ λιπαραὶ Χάριτες·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 121.1.3",
      "text": "καί σε ποτὶ ῥοδέῃσιν ἐπηχύναντο χέρεσσιν,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 121.1.4",
      "text": "κοῦρε, πεποίησαι δ’ ἡλίκος ἐσσὶ χάρις·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 121.5.1",
      "text": "τηλόθι μοι μάλα χαῖρε· πυρὸς δ’ οὐκ ἀσφαλὲς ἆσσον",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 121.5.2",
      "text": "ἕρπειν αὐηρήν, ἆ φίλος, ἀνθέρικα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 142.1.1",
      "text": "Ἰξῷ Δεξιόνικος ὑπὸ χλωρῇ πλατανίστῳ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 142.1.2",
      "text": "κόσσυφον ἀγρεύσας εἷλε κατὰ πτερύγων·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 142.1.3",
      "text": "χὠ μὲν ἀναστενάχων ἀπεκώκυεν ἱερὸς ὄρνις.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 142.1.4",
      "text": "ἀλλ’ ἐγώ, ὦ φίλ’ Ἔρως καὶ θαλεραὶ Χάριτες,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 142.5.1",
      "text": "εἴην καὶ κίχλη καὶ κόσσυφος, ὡς ἂν ἐκείνου",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 142.5.2",
      "text": "ἐν χερὶ καὶ φθογγὴν καὶ γλυκὺ δάκρυ βάλω.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 146.1.1",
      "text": "Ἀγρεύσας τὸν νεβρὸν ἀπώλεσα, χὠ μὲν ἀνατλὰς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 146.1.2",
      "text": "μυρία καὶ στήσας δίκτυα καὶ στάλικας",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 146.1.3",
      "text": "σὺν κενεαῖς χείρεσσιν ἀπέρχομαι· οἱ δ’ ἀμογητὶ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 146",
      "text": "τἀμὰ φέρουσιν, Ἔρως, οἷς σὺ γένοιο βαρύς.",
      "witness_prefix": "",
      "speaker": null
    }
  ],
