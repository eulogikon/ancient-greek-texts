    },
    {
      "kind": "text",
      "reference": "book 5.4",
      "text": "παρηυνάζοντο κάπῃσι, νηυσὶ δὲ πρηκτὰ κέλευθα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 5.5",
      "text": "Χελιδονίης ἀπὸ πέτρης",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 5.6",
      "text": "Πληγάδας ἀξείνους καὶ ὅπου",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 5.7",
      "text": "Φινήϊα δόρπα[ln_5]Ἅρπυιαι ἄτλητον ἐπὶ ψώαν",
