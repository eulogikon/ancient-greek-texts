  "research_html": "<div class=\"research-section\">\n<p class=\"research-text\">The Epigrams are a collection of eleven short poems attributed to the 2nd-century BCE Greek poet Nicander of Colophon. While Nicander is primarily known for his lengthy didactic works on toxicology, these pieces represent his engagement with the popular epigram form. Composed in elegiac couplets, they adhere to the genre&#x27;s traditional themes, including dedicatory inscriptions for gods and epitaphs for the deceased. The poems do not survive independently but are preserved within the Byzantine-era compilation known as the Greek Anthology, their transmission dependent on that larger manuscript tradition. Regarded as sophisticated products of Hellenistic literary culture, the epigrams are characterized by learned allusions, polished craftsmanship, and concise expression, reflecting the aesthetic values and mythological fluency expected of an educated contemporary audience.</p>\n</div>",
  "rows": [
    {
      "kind": "text",
      "reference": "book 435.1.1",
      "text": "Εὐπυλίδας, Ἐράτων, Χαῖρις, Λύκος, Ἆγις, Ἀλέξων,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 435.1.2",
      "text": "ἓξ Ἰφικρατίδα παῖδες, ἀπωλόμεθα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 435.1.3",
      "text": "Μεσσάνας ὑπὸ τεῖχος· ὁ δ’ ἕβδομος ἄμμε Γύλιππος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 435.1.4",
      "text": "ἐν πυρὶ θεὶς μεγάλαν ἦλθε φέρων σποδιάν,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 435.5",
      "text": "Σπάρτᾳ μὲν μέγα κῦδος, Ἀλεξίππᾳ δὲ μέγ’ ἄχθος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 435",
      "text": "ματρί· τὸ δ’ ἓν πάντων καὶ καλὸν ἐντάφιον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 526.1.1",
      "text": "Ζεῦ πάτερ, Ὀθρυάδα τίνα φέρτερον ἔδρακες ἄλλον,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 526.1.2",
      "text": "ὃς μόνος ἐκ Θυρέας οὐκ ἐθέλησε μολεῖν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 526.1.3",
      "text": "πατρίδ’ ἐπὶ Σπάρταν, διὰ δὲ ξίφος ἤλασε πλευρᾶν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 526.1.4",
      "text": "δοῦλα καταγράψας σκῦλα κατ’ Ἰναχιδᾶν;",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 503b.1",
      "text": "Ἵπποι γὰρ σφηκῶν γένεσις, ταῦροι δὲ μελισσῶν.",
      "witness_prefix": "",
      "speaker": null
    }
  ],
