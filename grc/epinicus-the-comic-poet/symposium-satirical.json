    {
      "kind": "text",
      "reference": "book 1.8",
      "text": "σκύφῳ χυτῆς λίθου, Δήμητρος ἀκτῇ πᾶν γεφυρώσας ὑγρόν[ln_10]κατῃσίμωκα πῶμα, καύματος λύσιν.“",
      "witness_prefix": "",
      "speaker": null
