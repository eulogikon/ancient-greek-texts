  "research_html": "<div class=\"research-section\">\n<p class=\"research-text\">The Epigrams of Alexander of Aetolia comprise a collection of fourteen short poems composed in Greek during the 3rd century BCE. Written in the elegiac couplet meter, these works engage with the conventional themes of the epigrammatic tradition, including erotic longing, votive offerings, and commemorative epitaphs. Among the most notable is an epitaph for the poet Erinna, which extols her literary skill and laments her premature death. The poems do not survive as an independent volume but are preserved within the later Byzantine compilation known as the Greek Anthology. Seven are contained in the core 10th-century manuscript of the Palatine Anthology, with the remaining seven attributed from other sources. This mode of transmission is characteristic of Hellenistic lyric poetry, where original collections are often lost and works persist through subsequent anthologies. Alexander was a scholar-poet associated with the Library of Alexandria, and his epigrams are considered products of a refined, courtly milieu. They exemplify the polished and allusive style cultivated in early Hellenistic literary circles, marking the epigram&#x27;s evolution from a simple inscribed form to a sophisticated genre of literary expression.</p>\n</div>",
  "rows": [
    {
      "kind": "text",
      "reference": "book 534.1.1",
      "text": "Ἄνθρωπε, ζωῆς περιφείδεο μηδὲ παρ’ ὥρην",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 534.1.2",
      "text": "ναυτίλος ἴσθι· καὶ ὣς οὐ πολὺς ἀνδρὶ βίος.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 534.1.3",
      "text": "δείλαιε Κλεόνικε, σὺ δ’ εἰς λιπαρὴν Θάσον ἐλθεῖν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 534.1.4",
      "text": "ἠπείγευ, Κοίλης ἔμπορος ἐκ Συρίης,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 534.5.1",
      "text": "ἔμπορος, ὦ Κλεόνικε· δύσιν δ’ ὑπὸ Πλειάδος αὐτὴν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 534.5.2",
      "text": "ποντοπορῶν αὐτῇ Πλειάδι συγκατέδυς.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 709.1.1",
      "text": "Σάρδιες ἀρχαῖαι, πατέρων νομός, εἰ μὲν ἐν ὑμῖν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 709.1.2",
      "text": "ἐτρεφόμαν, κερνᾶς ἦν τις ἂν ἢ μακελᾶς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 709.1.3",
      "text": "χρυσοφόρος ῥήσσων καλὰ τύμπανα· νῦν δέ μοι Ἀλκμὰν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 709.1.4",
      "text": "οὔνομα καὶ Σπάρτας εἰμὶ πολυτρίποδος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 709.5",
      "text": "καὶ Μούσας ἐδάην Ἑλικωνίδας, αἵ με τυράννων",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 709",
      "text": "θῆκαν Δασκύλεω μείζονα καὶ Γύγεω.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 172.1",
      "text": "Αὐτά που τὰν Κύπριν ἀπηκριβώσατο Παλλὰς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 172",
      "text": "τᾶς ἐπ’ Ἀλεξάνδρου λαθομένα κρίσιος.",
      "witness_prefix": "",
      "speaker": null
    }
  ],
