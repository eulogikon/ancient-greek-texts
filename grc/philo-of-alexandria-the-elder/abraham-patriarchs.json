      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 682.3",
      "text": "παρακλιδὸν ἀθροισθέντος· ἀλλ’ ὁ μὲν ἐν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 682.4",
      "text": "χείρεσσι κερασφόρον ὤπασε κριόν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
