      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 5.12",
      "text": "σποδεῖν; λέγ’ αὐτή, γλυκυτάτη, ἔλεγχ’ ἄγροικον οὖσαν ἡμῶν τὴν τύχην.",
      "witness_prefix": "",
