    {
      "kind": "text",
      "reference": "book 5.5",
      "text": "τοὺς ἱππέας ἐπὶ κῶμον εἰς Κόρινθον ἡμέρας δέκα, στεφάνους ἔχοντας καὶ μύρον",
      "witness_prefix": "",
      "speaker": null
    },
    {
