  "research_html": "<div class=\"research-section\">\n<p class=\"research-text\">The Epigrams is a collection of twenty-four short lyric poems attributed to Mesomedes of Crete, a Greek poet and composer active during the second century CE. A freedman and court poet for Emperor Hadrian, Mesomedes composed within the sophisticated, Hellenizing culture of the Roman imperial court. The poems belong to the traditional Greek epigram genre, featuring concise verses on typical themes such as dedications to gods, funerary epitaphs, and occasional poetry for social or ceremonial events. The complete collection survives intact, preserved not in standalone manuscripts but within the larger Byzantine compilation known as the Greek Anthology, specifically in Book 16 of the Anthologia Palatina. While Mesomedes is also noted for hymns that survive with ancient musical notation, the epigrams are transmitted as text only. Modern scholars interpret these works as examples of skilled courtly poetry, intended for an educated elite who appreciated the revival of classical Greek literary forms during the period often called the Second Sophistic. Their preservation in the anthology ensured his epigrammatic work was rediscovered and studied during the Renaissance.</p>\n</div>",
  "rows": [
    {
      "kind": "text",
      "reference": "book 63.1.1",
      "text": "Ἕρπουσα, βεβῶσα, ποτωμένα,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 63.1.2",
      "text": "νόθον ἴχνος ἀειρομένα δρομάς,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 63.1.3",
      "text": "πτερόεσσα μὲν ἦν τὰ πρόσω γυνά,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 63.1.4",
      "text": "τὰ δὲ μέσσα βρέμουσα λέαινα θήρ,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 63.5.1",
      "text": "τὰ δ’ ὄπισθεν ἑλισσόμενος δράκων.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 63.5.2",
      "text": "οὔθ’ ὁλκὸς ἀπέτρεχεν, οὐ γυνά,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 63.5.3",
      "text": "οὔτ’ ὄρνις ὅλον δέμας οὔτε θήρ·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 63.5.4",
      "text": "κούρα γὰρ ἐφαίνετ’ ἄνευ ποδῶν,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 63.5.5",
      "text": "κεφαλὰν δ’ οὐκ ἔσχε βρέμουσα θήρ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 63.10",
      "text": "φύσιν εἶχεν ἄτακτα κεκραμέναν·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 63",
      "text": "ἀτέλεστα τέλεια μεμιγμένα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 323.1.1",
      "text": "Τὰν ὕελον ἐκόμιζε",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 323.1.2",
      "text": "κόψας ἐργάτας ἀνήρ·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 323.1.3",
      "text": "ἐς δὲ πῦρ ἔθηκε βῶλον,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 323.1.4",
      "text": "ὡς σίδηρον εὐσθενῆ·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 323.5.1",
      "text": "ἁ δ’ ὕελος οἷα κηρὸς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 323.5.2",
      "text": "ἐξεχεῖτο παμφάγοισι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 323.5.3",
      "text": "φλοξὶν ἐκπυρουμένα·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 323.5.4",
      "text": "θαῦμα δ’ ἦν ἰδεῖν βροτοῖς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 323.5.5",
      "text": "ὁλκὸν ἐκ πυρὸς ῥέοντα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 323.10.1",
      "text": "καὶ τὸν ἐργάτην τρέμοντα,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 323.10.2",
      "text": "μὴ πεσὼν διαρραγῇ·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 323.10.3",
      "text": "ἐς δὲ διπτύχων ἀκμὰς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 323",
      "text": "χηλέων ἔθηκε βῶλον ...",
