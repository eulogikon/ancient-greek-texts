    {
      "kind": "text",
      "reference": "book 82.1",
      "text": "τί τυ ἐγὼν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 82.2",
      "text": "ποιέω;",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 83.1",
      "text": "ἐκπεφάναντί τεος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 83.2",
      "text": "ταὶ δυσθαλίαι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 84.1",
      "text": "οὐχ ἥσσων",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 84.2",
      "text": "τεοῦ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 85",
      "text": "τουτῶ θάμεθα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 86",
      "text": "μόνον ἐμίνγα τὸ τοῦ γόγγρου τέμαχος.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 87",
      "text": "οὐκέτι οἱ δωσῶ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 88",
      "text": "τί οὐ παρ’ ἔμ’ ἐστράφθη;",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 89",
      "text": "ὑμέων γὰρ ἀπρὶξ ἔχονται.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 90.1",
      "text": "ὃ δ’ ἐκ τῶ σκότεος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 90.2",
      "text": "τοξεύων αἰὲν ἕνα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 90.3",
      "text": "τινὰ ὧν ζυγαστροφεῖ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 91",
      "text": "ὅσα κα ὗμιν αἰνέσω.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 92.1",
      "text": "οὐ μάν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 92.2",
      "text": "τοι δίφρον ἐπημμένον ὑμίν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 94.1",
      "text": "πῶς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 94.2",
      "text": "ψε καὶ γινώσκομες;",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 95",
      "text": "τίς μοι τὰ λᾶια ἐκτίλλει;",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 96*",
      "text": "οὐδ’ ὅπως ἄριστα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 97*.1",
      "text": "ταυτᾶι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 97*.2",
      "text": "ταὶ θύραι, μᾶτερ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 98*.1",
      "text": "εἷ τὰ τῶν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 98*.2",
      "text": "χοιραγχᾶν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 99",
      "text": "ὕδωρ ἄκρατον εἰς τὰν κύλικα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 100",
      "text": "στρουθωτὰ ἑλίγματα ἐντετμαμένα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 101.1",
      "text": "μελαινίδες γάρ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 101.2",
      "text": "τοι νισοῦντι ἐμὶν ἐκ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 101.3",
      "text": "τοῦ μικροῦ λιμένος.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 104",
      "text": "βόες δὲ λαρινεύονται.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 105",
      "text": "κατάστρεψον, τέκνον, τὰν ἡμίναν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 106",
      "text": "κἠκρατηρίχημες",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 110.1",
      "text": "ἐκ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 110.2",
      "text": "τοῦ ὄνυχος γὰρ τὸν λέοντα ἔγραψεν. τορύναν ἔξεσεν. κύμινον ἔπρισεν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 117",
      "text": "ἐν ὅσσωι δέει δαδύσσεσθε.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 118",
      "text": "ἔχε τὸ δελήτιον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 120",
      "text": "φέρε τὸ θαύμακτρον κἠπιθυσιῶμες.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 121*",
      "text": "ναὶ κάρρων 〈ὁ〉 βῶς.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 123",
      "text": "ἐγὼ δὲ σίτου μὲν οὐδὲν ὀζαίνομαι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 125",
      "text": "πῶ τις ὦν ὄνον ὠνασεῖται;",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 126.1",
      "text": "τῶι χόλωι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 126.2",
      "text": "χρέομαι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 127",
      "text": "κινησῶ δ’ ἤδη καὶ τὸν ἀφ’ ἱαρᾶς.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 129.1",
      "text": "δειπνήσας ὠστίζεται",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 129.2",
      "text": "τοῖς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 129.3",
      "text": "τρηματιζόντεσσι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 131",
      "text": "Ποτιδᾶ δραστοχαῖτα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 134",
      "text": "ὁδαῖός γ’ ἐσσί.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 135*",
      "text": "λαδρέοντι δὲ τοὶ μυκτῆρες.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 144*.1",
      "text": "νῦν τ’ ἦνθες ἐς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 144*.2",
      "text": "χορὸν νῦν τ’ ἔπραδες.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 149",
      "text": "αἴ τις τὸν ξύοντα ἀντιξύει.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 150",
      "text": "ὁ χοραγὸς ξύεται.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 156",
      "text": "τῆτέ τοι κορῶναί ἐντι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 157",
      "text": "ἀργυρίων δεήσηι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 158",
      "text": "ἰλλοτέρα τᾶν κορωνᾶν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 163",
      "text": "κορώνας ἀνδούμενοι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 165",
      "text": "κύμβου ὄγκον ἔχων.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 166",
      "text": "ἀεὶ δὲ πρὸς ἀῶ φύλλα ῥάμνου κραστιζόμεθα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 168",
      "text": "μοῖτον ἀντὶ μοίτου.",
      "witness_prefix": "",
      "speaker": null
    }
  ],
