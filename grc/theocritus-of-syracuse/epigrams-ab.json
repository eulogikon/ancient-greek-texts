  "research_html": "<div class=\"research-section\">\n<p class=\"research-text\">The Epigrams constitute a collection of short poems attributed to Theocritus of Syracuse, the foundational poet of the pastoral genre who flourished in the 3rd century BCE. Composed in the elegiac couplets conventional for the form, these 124 pieces engage with traditional epigrammatic themes, including votive dedications to deities, funerary epitaphs, expressions of erotic sentiment, and commentary on art and literature. A handful exhibit the pastoral motifs for which Theocritus is most celebrated, providing a thematic link to his <strong>Idylls</strong>. The collection survives not as an independent ancient volume but through its incorporation into later comprehensive anthologies, principally the <strong>Palatine Anthology</strong> and the <strong>Planudean Anthology</strong>. The authenticity of the entire corpus remains a subject of scholarly contention; while certain epigrams are generally accepted as genuine, others are considered likely to be later attributions. These concise and artful verses were likely composed for the literate circles of Hellenistic courts, such as those in Alexandria and Syracuse, intended either for actual inscription or for circulation as sophisticated literary exercises.</p>\n</div>",
  "rows": [
    {
      "kind": "text",
      "reference": "book 336.1.1",
      "text": "Τὰ ῥόδα τὰ δροσόεντα καὶ ἁ κατάπυκνος ἐκείνα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 336.1.2",
      "text": "ἕρπυλλος κεῖται ταῖς Ἑλικωνιάσιν,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 336.1.3",
      "text": "ταὶ δὲ μελάμφυλλοι δάφναι τίν, Πύθιε Παιάν,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 336.1.4",
      "text": "Δελφὶς ἐπεὶ πέτρα τοῦτό τοι ἀγλάισε·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 336.5.1",
      "text": "βωμὸν δ’ αἱμάξει κεραὸς τράγος, οὗτος ὁ μᾶλος,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 336.5.2",
      "text": "τερμίνθου τρώγων ἔσχατον ἀκρεμόνα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 337.1.1",
      "text": "Ἦλθε καὶ ἐς Μίλατον ὁ τῶ Παιήονος υἱὸς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 337.1.2",
      "text": "ἰητῆρι νόσων ἀνδρὶ συνοισόμενος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 337.1.3",
      "text": "Νικίᾳ, ὅς μιν ἐπ’ ἆμαρ ἀεὶ θυέεσσιν ἱκνεῖται",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 337.1.4",
      "text": "καὶ τόδ’ ἀπ’ εὐώδους γλύψατ’ ἄγαλμα κέδρου,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 337.5.1",
      "text": "Ἠετίωνι χάριν γλαφυρᾶς χερὸς ἄκρον ὑποστὰς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 337.5.2",
      "text": "μισθόν· ὁ δ’ εἰς ἔργον πᾶσαν ἀφῆκε τέχναν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 338.1.1",
      "text": "Ὑμῖν τοῦτο, θεαί, κεχαρισμένον ἄνθετο πάσαις",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 338.1.2",
      "text": "τὤγαλμα Ξενοκλῆς, τοῦτο τὸ μαρμάρινον,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 338.1.3",
      "text": "μουσικός· οὐχ ἑτέρως τις ἐρεῖ. σοφίᾳ δ’ ἐπὶ τᾷδε",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 338.1.4",
      "text": "αἶνον ἔχων Μουσέων οὐκ ἐπιλανθάνεται.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 339.1.1",
      "text": "Δαμομένης ὁ χοραγός, ὁ τὸν τρίποδ’, ὦ Διόνυσε,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 339.1.2",
      "text": "καὶ σὲ τὸν ἅδιστον θεῶν μακάρων ἀναθείς,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 339.1.3",
      "text": "μέτριος ἦν ἐν πᾶσι· χορῷ δ’ ἐκτάσατο νίκαν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 339",
      "text": "ἀνδρῶν, καὶ τὸ καλὸν καὶ τὸ προσῆκον ὁρῶν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 340.1.1",
      "text": "Ἁ Κύπρις οὐ πάνδαμος· ἱλάσκεο τὰν θεὸν εἰπὼν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 340.1.2",
      "text": "Οὐρανίαν, ἁγνᾶς ἄνθεμα Χρυσογόνας",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 340.1.3",
      "text": "οἴκῳ ἐν Ἀμφικλέους, ᾧ καὶ τέκνα καὶ βίον ἔσχε",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 340.1.4",
      "text": "ξυνόν· ἀεὶ δέ σφιν λώιον εἰς ἔτος ἦν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 340.5.1",
      "text": "ἐκ σέθεν ἀρχομένοις, ὦ πότνια· κηδόμενοι γὰρ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 340.5.2",
      "text": "ἀθανάτων αὐτοὶ πλεῖον ἔχουσι βροτοί.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 262.1.1",
      "text": "Αὐδήσει τὸ γράμμα, τί σᾶμά τε καὶ τίς ὑπ’ αὐτῷ·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 262.1.2",
      "text": "„Γλαύκης εἰμὶ τάφος τῆς ὀνομαζομένης.“",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 658.1.1",
      "text": "Γνώσομαι, εἴ τι νέμεις ἀγαθοῖς πλέον ἢ καὶ ὁ δειλὸς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 658.1.2",
      "text": "ἐκ σέθεν ὡσαύτως ἶσον, ὁδοιπόρ’, ἔχει.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 658.1.3",
      "text": "„Χαιρέτω οὗτος ὁ τύμβοσ“, ἐρεῖς, „ἐπεὶ Εὐρυμέδοντος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 658.1.4",
      "text": "κεῖται τῆς ἱερῆς κοῦφος ὑπὲρ κεφαλῆς.“",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 338.1.1",
      "text": "Εὕδεις φυλλοστρῶτι πέδῳ, Δάφνι, σῶμα κεκμακὸς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 338.1.2",
      "text": "ἀμπαύων· στάλικες δ’ ἀρτιπαγεῖς ἀν’ ὄρη.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 338.1.3",
      "text": "ἀγρεύει δέ τυ Πὰν καὶ ὁ τὸν κροκόεντα Πρίηπος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 338.1.4",
      "text": "κισσὸν ἐφ’ ἱμερτῷ κρατὶ καθαπτόμενος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 338.5.1",
      "text": "ἄντρον ἔσω στείχοντες ὁμόρροθοι. ἀλλὰ τὺ φεῦγε,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 338.5.2",
      "text": "φεῦγε, μεθεὶς ὕπνου κῶμα καταγρόμενον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 432.1.1",
      "text": "Ἆ δείλαιε τὺ Θύρσι, τί τοι πλέον, εἰ καταταξεῖς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 432.1.2",
      "text": "δάκρυσι διγλήνως ὦπας ὀδυρόμενος;",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 432.1.3",
      "text": "οἴχεται ἁ χίμαρος, τὸ καλὸν τέκος, οἴχετ’ ἐς Ἅιδαν·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 432.1.4",
      "text": "τραχὺς γὰρ χαλαῖς ἀμφεπίαξε λύκος,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 432.5",
      "text": "αἱ δὲ κύνες κλαγγεῦντι. τί τοι πλέον, ἁνίκα τήνας",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 432",
      "text": "ὀστίον οὐδὲ τέφρα λείπετ’ ἀποιχομένας;",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 433.1.1",
      "text": "Λῇς, ποτὶ τᾶν Νυμφᾶν, διδύμοις αὐλοῖσιν ἀεῖσαι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 433.1.2",
      "text": "ἁδύ τί μοι; κἠγὼ πακτίδ’ ἀειράμενος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 433.1.3",
      "text": "ἀρξεῦμαί τι κρέκειν· ὁ δὲ βουκόλος ἄμμιγα θέλξει",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 433.1.4",
      "text": "Δάφνις κηροδέτῳ πνεύματι μελπόμενος·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 433.5.1",
      "text": "ἐγγὺς δὲ στάντες λασιαύχενος ἄντρου ὄπισθεν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 433.5.2",
      "text": "Πᾶνα τὸν αἰγιβάταν ὀρφανίσωμες ὕπνου.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 434.1.1",
      "text": "Ἄλλος ὁ Χῖος· ἐγὼ δὲ Θεόκριτος, ὃς τάδ’ ἔγραψα,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 434.1.2",
      "text": "εἷς ἀπὸ τῶν πολλῶν εἰμὶ Συρακοσίων,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 434.1.3",
      "text": "υἱὸς Πραξαγόραο περικλειτῆς τε Φιλίννης·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 434.1.4",
      "text": "Μοῦσαν δ’ ὀθνείαν οὔ τιν’ ἐφελκυσάμαν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 435.1.1",
      "text": "Ἀστοῖς καὶ ξείνοισιν ἴσον νέμει ἅδε τράπεζα·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 435.1.2",
      "text": "θεὶς ἀνελεῦ ψήφου πρὸς λόγον ἐρχομένης.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 435.1.3",
      "text": "ἄλλος τις πρόφασιν λεγέτω, τὰ δ’ ὀθνεῖα Κάικος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 435",
      "text": "χρήματα καὶ νυκτὸς βουλομένοις ἀριθμεῖ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 437.1.1",
      "text": "Τήναν τὰν λαύραν, τόθι ταὶ δρύες, αἰπόλε, κάμψας",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 437.1.2",
      "text": "σύκινον εὑρήσεις ἀρτιγλυφὲς ξόανον,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 437.1.3",
      "text": "τρισκελές, αὐτόφλοιον, ἀνούατον, ἀλλὰ φάλητι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 437.1.4",
      "text": "παιδογόνῳ δυνατὸν Κύπριδος ἔργα τελεῖν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 437.5.1",
      "text": "ἕρκος δ’ εὐίερον περιδέδρομεν· ἀέναον δὲ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 437.5.2",
      "text": "ῥεῖθρον ἀπὸ σπιλάδων πάντοσε τηλεθάει",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 437.5.3",
      "text": "δάφναις καὶ μύρτοισι καὶ εὐώδει κυπαρίσσῳ,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 437.5.4",
      "text": "ἔνθα πέριξ κέχυται βοτρυόπαις ἕλικι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 437.5.5",
      "text": "ἄμπελος· εἰαρινοὶ δὲ λιγυφθόγγοισιν ἀοιδαῖς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 437.10.1",
      "text": "κόσσυφοι ἀχεῦσιν ποικιλότραυλα μέλη·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 437.10.2",
      "text": "ξουθαὶ δ’ ἀδονίδες μινυρίσμασιν ἀνταχεῦσι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 437.10.3",
      "text": "μέλπουσαι στόμασιν τὰν μελίγαρυν ὄπα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 437.10.4",
      "text": "ἕζεο δὴ τηνεὶ καὶ τῷ χαρίεντι Πριάπῳ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 437.10.5",
      "text": "εὔχου ἀποστέρξαι τοὺς Δάφνιδός με πόθους,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 437.15.1",
      "text": "κεὐθὺς ἀπορρέξειν χίμαρον καλόν· ἢν δ’ ἀνανεύσῃ,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 437.15.2",
      "text": "τοῦδε τυχὼν ἐθέλω τρισσὰ θύη τελέσαι·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 437.15.3",
      "text": "ῥέξω γὰρ δαμάλαν, λάσιον τράγον, ἄρνα τὸν ἴσχω",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 437",
      "text": "σακίταν· νεύοι δ’ εὐμενέως ὁ θεός.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 598.1.1",
      "text": "Τὸν τῶ Ζανὸς ὅδ’ ὗμιν υἱὸν ὡνήρ,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 598.1.2",
      "text": "τὸν λειοντομάχαν, τὸν ὀξύχειρα,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 598.1.3",
      "text": "πρᾶτος τῶν ἐπάνωθε μουσοποιῶν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 598.1.4",
      "text": "Πείσανδρος συνέγραψεν οὑκ Καμίρου,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 598.5.1",
      "text": "χὤσσους ἐξεπόνασεν, εἶπ’ ἀέθλους·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 598.5.2",
      "text": "τοῦτον δ’ αὐτὸν ὁ δᾶμος, ὡς σάφ’ εἰδῇς,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 598.5.3",
      "text": "ἔστας’ ἐνθάδε χάλκεον ποήσας",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 598.5.4",
      "text": "πολλοῖς μησὶν ὄπισθε κἠνιαυτοῖς.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 599.1.1",
      "text": "Θᾶσαι τὸν ἀνδριάντα τοῦτον, ὦ ξένε,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 599.1.2",
      "text": "σπουδᾷ καὶ λέγ’, ἐπὰν ἐς οἶκον ἔνθῃς·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 599.1.3",
      "text": "„Ἀνακρέοντος εἰκόν’ εἶδον ἐν Τέῳ,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 599.1.4",
      "text": "τῶν πρόσθ’ εἴ τι περισσὸν ᾠδοποιοῦ.“",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 599.5.1",
      "text": "προσθεὶς δὲ χὤτι τοῖς νέοισιν ἅδετο,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 599.5.2",
      "text": "ἐρεῖς ἀτρεκέως ὅλον τὸν ἄνδρα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 600.1.1",
      "text": "Ἅ τε φωνὰ Δώριος χὠνὴρ ὁ τὰν κωμῳδίαν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 600.1.2",
      "text": "εὑρών, Ἐπίχαρμος.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 600.1.3",
      "text": "ὦ Βάκχε, χάλκεόν νιν ἀντ’ ἀλαθινοῦ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 600.1.4",
      "text": "τὶν ὧδ’ ἀνέθηκαν,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 600.5.1",
      "text": "τοὶ Συρακούσσαις ἐνίδρυνται, πελωρίστᾳ πόλει,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 600.5.2",
      "text": "οἷ, ἀνδρὶ πολίτᾳ,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 600.5.3",
      "text": "—σωρὸν γὰρ εἶχε ῥημάτων—μεμναμένοι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 600.5.4",
      "text": "τελεῖν ἐπίχειρα·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 600.5.5",
      "text": "πολλὰ γὰρ ποττὰν ζόαν τοῖς πᾶσιν εἶπε χρήσιμα·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 600.10",
      "text": "μεγάλα χάρις αὐτῷ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.1.1",
      "text": "Ὁ μουσοποιὸς ἐνθάδ’ Ἱππῶναξ κεῖται.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.1.2",
      "text": "εἰ μὲν πονηρός, μὴ ποτέρχευ τῷ τύμβῳ·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.1.3",
      "text": "εἰ δ’ ἐσσὶ κρήγυός τε καὶ παρὰ χρηστῶν,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.1.4",
      "text": "θαρσέων καθίζευ, κἢν θέλῃς, ἀπόβριξον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.1.1",
      "text": "Οὐδενὸς εὐνάτειρα, Μακροπτολέμοιο δὲ μάτηρ,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.1.2",
      "text": "μαίας ἀντιπέτροιο θοὸν τέκεν ἰθυντῆρα,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.1.3",
      "text": "οὐχὶ Κεράσταν, ὅν ποτε θρέψατο ταυροπάτωρ,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.1.4",
      "text": "ἀλλ’ οὗ πειλιπὲς αἶθε πάρος φρένα τέρμα σάκους",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.5.1",
      "text": "οὔνομ’ Ὅλον, δίζων, ὃς τᾶς Μέροπος πόθον",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.5.2",
      "text": "κούρας γηρυγόνας ἔχε τᾶς ἀνεμώδεος,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.5.3",
      "text": "ὃς Μοίσᾳ λιγὺ πᾶξεν ἰοστεφάνῳ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.5.4",
      "text": "ἕλκος, ἄγαλμα πόθοιο πυρισμαράγου,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.5.5",
      "text": "ὃς σβέσεν ἀνορέαν ἰσαυδέα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.10.1",
      "text": "παπποφόνου Τυρίας τ’ 〈ἐξήλασεν〉,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.10.2",
      "text": "ᾧ τόδε τυφλοφόρων ἐρατὸν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.10.3",
      "text": "πᾶμα Πάρις θέτο Σιμιχίδας.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.10.4",
      "text": "ψυχὰν ᾇ, βροτοβάμων,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.10.5",
      "text": "στήτας οἶστρε Σαέττας,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.15.1",
      "text": "κλωποπάτωρ, ἀπάτωρ,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.15.2",
      "text": "λαρνακόγυιε, χαρεὶς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.15.3",
      "text": "ἁδὺ μελίσδοις",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.15.4",
      "text": "ἔλλοπι κούρᾳ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.15.5",
      "text": "Καλλιόπᾳ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.20",
      "text": "νηλεύστῳ.",
      "witness_prefix": "",
      "speaker": null
    }
  ],
