    {
      "kind": "text",
      "reference": "book 2.1",
      "text": "Ὁ γὰρ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.2",
      "text": "χρόνος μ’ ἔκαμψε, τέκτων μὲν",
