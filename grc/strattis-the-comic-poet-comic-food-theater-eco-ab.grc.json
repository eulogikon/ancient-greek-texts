      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.4",
      "text": "χελιδόνας, τὴν ἔνθεσιν δ’ ἄκολον, τὸ γελᾶν δὲ κριδδέμεν, νεασπάτωτον δ’ ἤν",
      "witness_prefix": "",
