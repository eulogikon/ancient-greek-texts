      "text": "ἁλύσιον εἶχε",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 33.2",
      "text": "τετταράκοντ’ ἄγον δραχμάς.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
