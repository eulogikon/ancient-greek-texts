      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.4",
      "text": "στρέφει δαίμων ἑκάστῳ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.1",
      "text": "Ἀρτίως διηρτάμηκε καὶ τὰ μὲν διανεκῆ σώματος μέρη δαμάζετ’ ἐν",
      "witness_prefix": "",
      "speaker": null
