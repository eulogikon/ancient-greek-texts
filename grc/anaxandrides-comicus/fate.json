    {
      "kind": "text",
      "reference": "book 1.12",
      "text": "τε πνοαί; τερενοχρῶτες μαζῶν ὄψεις, ἄρτων, ἀμύλων, πουλυποδείων, χολίκων, δημοῦ,",
      "witness_prefix": "",
