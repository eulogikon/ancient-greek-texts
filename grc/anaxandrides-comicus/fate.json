    },
    {
      "kind": "text",
      "reference": "book 2.3",
      "text": "πονοῦμεν. τὸν ἀσύμβολον εὗρε γελοῖα λέγειν Ῥαδάμανθυς καὶ Πα‐[ln_2]λαμήδης.",
      "witness_prefix": "",
