      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 7.9",
      "text": "τι καὶ θαυμαστὸν ἂν εἴη, εἰ μηδέτερος ὑμῶν μηδὲν δρᾶσαι δύναιτο. ἔπειτα οἴει",
      "witness_prefix": "",
      "speaker": null
