    },
    {
      "kind": "text",
      "reference": "book 9.6",
      "text": "πτωχὸς καὶ μα‐[ln_5]στιγίας ὢν μέλλοιμι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 9.7",
      "text": "τοὺς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 9.8",
