    {
      "kind": "text",
      "reference": "book 4.1",
      "text": "σχεδὸν μὲν οὖν ἐστιν ἅπαντα ὅμοια. οἵ τε γὰρ διαθέν‐ τες τὸν ἀγῶνα φάσκοντες εἶναι βασιλεῖς",
      "witness_prefix": "",
