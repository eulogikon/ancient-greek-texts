  "research_html": "<div class=\"research-section\">\n<p class=\"research-text\">&quot;Myrson and Lycidas&quot; is a pastoral poem by the Hellenistic bucolic poet Bion of Smyrna, who likely wrote in the late second or early first century BCE. Structured as an amoebaean singing contest between two shepherds, it employs a conventional Theocritean format. The work survives only in fragments; the thirty-two extant lines are compiled from disparate sources and do not constitute a complete poem. The fragmentary verses depict a competitive exchange between the shepherds Myrson and Lycidas, touching upon subjects common to the pastoral genre such as love and rustic life. The poem is preserved through quotations in later grammatical and lexicographical works, such as the <strong>Etymologicum Magnum</strong>. Unlike Bion&#x27;s more fully transmitted &quot;Lament for Adonis,&quot; &quot;Myrson and Lycidas&quot; lacks a continuous manuscript tradition. As part of the Hellenistic bucolic canon, Bion&#x27;s work, including this fragmentary contest, helped solidify the pastoral dialogue as a literary form, a tradition that directly influenced later poets, most notably Virgil in his <strong>Eclogues</strong>.</p>\n</div>",
  "rows": [
    {
      "kind": "text",
      "reference": "spkr1",
      "text": "ΜΥΡΣΩΝ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "1.1",
      "text": "Λῇς νύ τί μοι, Λυκίδα, Σικελὸν μέλος ἁδὺ λιγαίνειν,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "1.2",
      "text": "ἱμερόεν γλυκύθυμον ἐρωτικόν, οἷον ὁ Κύκλωψ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "1.3",
      "text": "ἄεισεν Πολύφαμος ἐπ’ ᾐόνι 〈τᾷ〉 Γαλατείᾳ;",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "spkr2",
      "text": "ΛΥΚΙΔΑΣ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "4",
      "text": "κἠμοὶ συρίσδεν, Μύρσων, φίλον, ἀλλὰ τί μέλψω;",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "5.1",
      "text": "ΜΥ. Σκύριον 〈ὅν〉, Λυκίδα, ζαλώμενος ᾆδες ἔρωτα,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "5.2",
      "text": "λάθρια Πηλεΐδαο φιλάματα, λάθριον εὐνάν, πῶς παῖς ἕσσατο φᾶρος, ὅπως δ’ ἐψεύσατο μορφάν,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "5.3",
      "text": "χὤπως ἐν κώραις Λυκομηδίσιν †ἅπαλέγοισαι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "5.4",
      "text": "ἠείδη κατὰ παστὸν Ἀχιλλέα Δηιδάμεια.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "10.1",
      "text": "ΛΥ. ἅρπασε τὰν Ἑλέναν πόθ’ ὁ βωκόλος, ἆγε δ’ ἐς Ἴδαν,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "10.2",
      "text": "Οἰνώνῃ κακὸν ἄλγος. ἐχώσατο 〈δ’〉 ἁ Λακεδαίμων",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "10.3",
      "text": "πάντα δὲ λαὸν ἄγειρεν Ἀχαϊκόν, οὐδέ τις Ἕλλην,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "10.4",
      "text": "οὔτε Μυκηναίων οὔτ’ Ἤλιδος οὔτε Λακώνων,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "10.5",
      "text": "μεῖνεν ἑὸν κατὰ δῶμα φυγὼν δύστανον Ἄρηα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "15.1",
      "text": "λάνθανε δ’ ἐν κώραις Λυκομηδίσι μοῦνος Ἀχιλλεύς,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "15.2",
      "text": "εἴρια δ’ ἀνθ’ ὅπλων ἐδιδάσκετο, καὶ χερὶ λευκᾷ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "15.3",
      "text": "παρθενικὸν κόρον εἶχεν, ἐφαίνετο δ’ ἠύτε κώρα·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "15.4",
      "text": "καὶ γὰρ ἴσον τήναις θηλύνετο, καὶ τόσον ἄνθος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "15.5",
      "text": "χιονέαις πόρφυρε παρηίσι, καὶ τὸ βάδισμα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "20.1",
      "text": "παρθενικῆς ἐβάδιζε, κόμας δ’ ἐπύκαζε καλύπτρῃ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "20.2",
      "text": "θυμὸν δ’ ἀνέρος εἶχε καὶ ἀνέρος εἶχεν ἔρωτα·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "20.3",
      "text": "ἐξ ἀοῦς δ’ ἐπὶ νύκτα παρίζετο Δηιδαμείᾳ,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "20.4",
      "text": "καὶ ποτὲ μὲν τήνας ἐφίλει χέρα, πολλάκι δ’ αὐτᾶς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "20.5",
      "text": "στάμονα καλὸν ἄειρε τὰ δαίδαλα δ’ ἄτρι’ ἐπῄνει·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "25.1",
      "text": "ἤσθιε δ’ οὐκ ἄλλᾳ σὺν ὁμάλικι, πάντα δ’ ἐποίει",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "25.2",
      "text": "σπεύδων κοινὸν ἐς ὕπνον. ἔλεξέ νυ καὶ λόγον αὐτᾷ·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "25.3",
      "text": "‘ἄλλαι μὲν κνώσσουσι σὺν ἀλλήλαισιν ἀδελφαί,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "25.4",
      "text": "αὐτὰρ ἐγὼ μούνα, μούνα δὲ σύ, νύμφα, καθεύδεις.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "25.5",
      "text": "αἱ δύο παρθενικαὶ συνομάλικες, αἱ δύο καλαί,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "30.1",
      "text": "ἀλλὰ μόναι κατὰ λέκτρα καθεύδομες, ἁ δὲ πονηρά",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "30.2",
      "text": "†νύσσα† δολία με κακῶς ἀπὸ σεῖο μερίσδει. οὐ γὰρ ἐγὼ σέο .....",
      "witness_prefix": "",
      "speaker": null
    }
  ],
