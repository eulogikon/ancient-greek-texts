    {
      "kind": "text",
      "reference": "book 19.3",
      "text": "τι κἀσύντακτόν ἐστιν, ὦ πάτερ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 20.1",
      "text": "ἀλλ’ ἐγχέασα θᾶττον ἀγαθοῦ δαίμονος ἀπενεγκάτω μοι τὴν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 20.2",
      "text": "τράπεζαν ἐκποδών· ἱκανῶς κεχόρτασμαι γάρ. Β. ἀγαθοῦ δαίμονος. Α. δέχομαι. λαβοῦς’ ἀπένεγκε",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 20.3",
      "text": "ταύτην ἐκποδών.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.1",
      "text": "ἔπειτα τῆς αὐτῆς ὁδοῦ πρὸς Ἀερόπην ἐλθοῦσα πέμψαι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 21.2",
      "text": "στρώματα αὐτὴν κέλευε, φησί, καὶ παρ’ Ὤκιμον",
