    {
      "kind": "text",
      "reference": "book 1.1",
      "text": "Τρίτον δὲ πρὸς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.2",
      "text": "τούτοισι τὸν",
