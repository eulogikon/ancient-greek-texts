  "research_html": "<div class=\"research-section\">\n<p class=\"research-text\">The Epigrams are a collection of ninety-three short Greek poems, traditionally ascribed to the philosopher Plato. Composed primarily in elegiac couplets, they encompass a diverse range of subjects, including epitaphs for the dead, such as the celebrated lines commemorating the Spartans who fell at Thermopylae, dedicatory verses to deities like Pan, expressions of love and desire, and philosophical meditations on life and mortality. The date of their composition is uncertain, and their authenticity has been contested since antiquity. Modern scholarship largely regards the majority as spurious, likely products of later imitators seeking the prestige of Plato&#x27;s name. Any genuine pieces among them may represent Plato&#x27;s early poetic endeavors prior to his philosophical career. The collection&#x27;s transmission history contributes significantly to the doubts surrounding its authorship; it does not appear in the medieval manuscripts preserving Plato&#x27;s philosophical dialogues but survives through later anthologies, most notably the Greek Anthology, and in the biographical accounts of Diogenes Laertius. Despite questions of origin, these epigrams have exerted a lasting influence, helping to cement Plato&#x27;s posthumous reputation as a master of concise and evocative verse.</p>\n</div>",
  "rows": [
    {
      "kind": "text",
      "reference": "book 78.1.1",
      "text": "Τὴν ψυχὴν Ἀγάθωνα φιλῶν ἐπὶ χείλεσιν ἔσχον·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 78.1.2",
      "text": "ἦλθε γὰρ ἡ τλήμων ὡς διαβησομένη.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 79.1.1",
      "text": "Τῷ μήλῳ βάλλω σε· σὺ δ’ εἰ μὲν ἑκοῦσα φιλεῖς με,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 79.1.2",
      "text": "δεξαμένη τῆς σῆς παρθενίης μετάδος.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 79.1.3",
      "text": "εἰ δ’ ἄρ’, ὃ μὴ γίγνοιτο, νοεῖς, τοῦτ’ αὐτὸ λαβοῦσα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 79",
      "text": "σκέψαι τὴν ὥρην ὡς ὀλιγοχρόνιος.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 80.1.1",
      "text": "Μῆλον ἐγώ· βάλλει με φιλῶν σέ τις. ἀλλ’ ἐπίνευσον,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 80.1.2",
      "text": "Ξανθίππη· κἀγὼ καὶ σὺ μαραινόμεθα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.1.1",
      "text": "Ἡ σοβαρὸν γελάσασα καθ’ Ἑλλάδος, ἡ τὸν ἐραστῶν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.1.2",
      "text": "ἑσμὸν ἐνὶ προθύροις Λαῒς ἔχουσα νέων,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.1.3",
      "text": "τῇ Παφίῃ τὸ κάτοπτρον, ἐπεὶ τοίη μὲν ὁρᾶσθαι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.1.4",
      "text": "οὐκ ἐθέλω, οἵη δ’ ἦν πάρος, οὐ δύναμαι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 43.1.1",
      "text": "Τὸν Νυμφῶν θεράποντα, φιλόμβριον, ὑγρὸν ἀοιδόν,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 43.1.2",
      "text": "τὸν λιβάσιν κούφαις τερπόμενον βάτραχον",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 43.1.3",
      "text": "χαλκῷ μορφώσας τις ὁδοιπόρος εὖχος ἔθηκε,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 43.1.4",
      "text": "καύματος ἐχθροτάτην δίψαν ἀκεσσάμενος.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 43.5.1",
      "text": "πλαζομένῳ γὰρ ἔδειξεν ὕδωρ, εὔκαιρον ἀείσας",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 43.5.2",
      "text": "κοιλάδος ἐκ δροσερῆς ἀμφιβίῳ στόματι·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 43.5.3",
      "text": "φωνὴν δ’ ἡγήτειραν ὁδοιπόρος οὐκ ἀπολείπων",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 43",
      "text": "εὗρε πόσιν γλυκερῶν, ὧν ἐπόθει, λιβάδων.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 99.1.1",
      "text": "Δάκρυα μὲν Ἑκάβῃ τε καὶ Ἰλιάδεσσι γυναιξὶ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 99.1.2",
      "text": "Μοῖραι ἐπέκλωσαν δὴ τότε γεινομέναις·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 99.1.3",
      "text": "σοὶ δέ, Δίων, ῥέξαντι καλῶν ἐπινίκιον ἔργων",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 99.1.4",
      "text": "δαίμονες εὐρείας ἐλπίδας ἐξέχεαν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 99.5",
      "text": "κεῖσαι δ’ εὐρυχόρῳ ἐν πατρίδι τίμιος ἀστοῖς,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 99",
      "text": "ὦ ἐμὸν ἐκμήνας θυμὸν ἔρωτι Δίων.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 100.1.1",
      "text": "Νῦν, ὅτε μηδὲν Ἄλεξις ὅσον μόνον εἶφ’ ὅτι καλός,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 100.1.2",
      "text": "ὦπται καὶ πάντῃ πᾶσι περιβλέπεται.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 100.1.3",
      "text": "θυμέ, τί μηνύεις κυσὶν ὀστέον; εἶτ’ ἀνιήσεις",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 100.1.4",
      "text": "ὕστερον. οὐχ οὕτω Φαῖδρον ἀπωλέσαμεν;",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 256.1.1",
      "text": "Οἵδε ποτ’ Αἰγαίοιο βαρύβρομον οἶδμα λιπόντες",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 256.1.2",
      "text": "Ἐκβατάνων πεδίῳ κείμεθ’ ἐνὶ μεσάτῳ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 256.1.3",
      "text": "χαῖρε, κλυτή ποτε πατρὶς Ἐρέτρια· χαίρετ’, Ἀθῆναι,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 256.1.4",
      "text": "γείτονες Εὐβοίης· χαῖρε, θάλασσα φίλη.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 259.1.1",
      "text": "Εὐβοίης γένος ἐσμὲν Ἐρετρικόν, ἄγχι δὲ Σούσων",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 259.1.2",
      "text": "κείμεθα· θεῦ, γαίης ὅσσον ἀφ’ ἡμετέρης.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 265.1.1",
      "text": "Ναυηγοῦ τάφος εἰμί, ὁ δ’ ἀντίον ἐστὶ γεωργοῦ·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 265.1.2",
      "text": "ὡς ἁλὶ καὶ γαίῃ ξυνὸς ὕπεστ’ Ἀίδης.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 268.1.1",
      "text": "Ναυηγόν με δέδορκας· ὃν ἡ κτείνασα θάλασσα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 268.1.2",
      "text": "γυμνῶσαι πυμάτου φάρεος ᾐδέσατο,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 268.1.3",
      "text": "ἄνθρωπος παλάμῃσιν ἀταρβήτοις μ’ ἀπέδυσε,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 268.1.4",
      "text": "τόσσον ἄγος τόσσου κέρδεος ἀράμενος.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 268.5.1",
      "text": "κεῖνο καὶ ἐνδύσαιτο καὶ εἰς Ἀίδαο φέροιτο,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 268.5.2",
      "text": "καί μιν ἴδοι Μίνως τοὐμὸν ἔχοντα ῥάκος.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 269.1.1",
      "text": "Πλωτῆρες, σῴζοισθε καὶ εἰν ἁλὶ καὶ κατὰ γαῖαν·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 269.1.2",
      "text": "ἴστε δὲ ναυηγοῦ σῆμα παρερχόμενοι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 669.1.1",
      "text": "Ἀστέρας εἰσαθρεῖς, Ἀστὴρ ἐμός· εἴθε γενοίμην",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 669.1.2",
      "text": "οὐρανός, ὡς πολλοῖς ὄμμασιν εἰς σὲ βλέπω.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 670.1.1",
      "text": "Ἀστὴρ πρὶν μὲν ἔλαμπες ἐνὶ ζωοῖσιν Ἑῷος·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 670.1.2",
      "text": "νῦν δὲ θανὼν λάμπεις Ἕσπερος ἐν φθιμένοις.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.1.1",
      "text": "Εἰνοδίην καρύην με παρερχομένοις ἐφύτευσαν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.1.2",
      "text": "παισὶ λιθοβλήτου παίγνιον εὐστοχίης·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.1.3",
      "text": "πάντας δ’ ἀκρεμόνας τε καὶ εὐθαλέας ὀροδάμνους",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.1.4",
      "text": "κέκλασμαι πυκιναῖς χερμάσι βαλλομένη·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.5",
      "text": "δένδρεσιν εὐκάρποις οὐδὲν πλέον· ἦ γὰρ ἔγωγε",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3",
      "text": "δυσδαίμων ἐς ἐμὴν ὕβριν ἐκαρποφόρουν.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 44.1.1",
      "text": "Χρυσὸν ἀνὴρ εὑρὼν ἔλιπε βρόχον· αὐτὰρ ὁ χρυσόν,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 44.1.2",
      "text": "ὃν λίπεν, οὐχ εὑρὼν ἧψεν, ὃν εὗρε, βρόχον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 51.1",
      "text": "Αἰὼν πάντα φέρει· δολιχὸς χρόνος οἶδεν ἀμείβειν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 51",
      "text": "οὔνομα καὶ μορφὴν καὶ φύσιν ἠδὲ τύχην.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 506.1.1",
      "text": "Ἐννέα τὰς Μούσας φασίν τινες· ὡς ὀλιγώρως·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 506.1.2",
      "text": "ἠνίδε καὶ Σαπφὼ Λεσβόθεν ἡ δεκάτη.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 747.1.1",
      "text": "Εἰκόνα πέντε βοῶν μικρὰ λίθος εἶχεν ἴασπις,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 747.1.2",
      "text": "ὡς ἤδη πάσας ἔμπνοα βοσκομένας.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 747.1.3",
      "text": "καὶ τάχα κἂν ἀπέφευγε τὰ βοίδια· νῦν δὲ κρατεῖται",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 747.1.4",
      "text": "τῇ χρυσῇ μάνδρῃ τὸ βραχὺ βουκόλιον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 823.1.1",
      "text": "Σιγάτω λάσιον Δρυάδων λέπας οἵ τ’ ἀπὸ πέτρας",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 823.1.2",
      "text": "κρουνοὶ καὶ βληχὴ πουλυμιγὴς τοκάδων,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 823.1.3",
      "text": "αὐτὸς ἐπεὶ σύριγγι μελίσδεται εὐκελάδῳ Πάν,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 823.1.4",
      "text": "ὑγρὸν ἱεὶς ζευκτῶν χεῖλος ὑπὲρ καλάμων·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 823.5",
      "text": "αἱ δὲ πέριξ θαλεροῖσι χορὸν ποσὶν ἐστήσαντο",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 823",
      "text": "Ὑδριάδες Νύμφαι, Νύμφαι Ἁμαδρυάδες.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 13.1.1",
      "text": "Ὑψίκομον παρὰ τάνδε καθίζεο φωνήεσσαν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 13.1.2",
      "text": "φρίσσουσαν πυκινοῖς κῶνον ὑπὸ ζεφύροις,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 13.1.3",
      "text": "καί σοι καχλάζουσιν ἐμοῖς παρὰ νάμασι σῦριγξ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 13.1.4",
      "text": "θελγομένῳ στάξει κῶμα κατὰ βλεφάρων.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 160.1.1",
      "text": "Ἡ Παφίη Κυθέρεια δι’ οἴδματος ἐς Κνίδον ἦλθε",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 160.1.2",
      "text": "βουλομένη κατιδεῖν εἰκόνα τὴν ἰδίην.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 160.1.3",
      "text": "πάντῃ δ’ ἀθρήσασα περισκέπτῳ ἐνὶ χώρῳ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 160.1.4",
      "text": "φθέγξατο· „Ποῦ γυμνὴν εἶδέ με Πραξιτέλης;“",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 160.5.1",
      "text": "Πραξιτέλης οὐκ εἶδεν, ἃ μὴ θέμις, ἀλλ’ ὁ σίδηρος",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 160.5.2",
      "text": "ἔξεσεν, οἷά γ’ Ἄρης ἤθελε, τὴν Παφίην.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 161.1.1",
      "text": "Οὔτε σε Πραξιτέλης τεχνάσατο οὔθ’ ὁ σίδαρος·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 161.1.2",
      "text": "ἀλλ’ οὕτως ἔστης ὥς ποτε κρινομένη.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 210.1.1",
      "text": "Ἄλσος δ’ ὡς ἱκόμεσθα βαθύσκιον, εὕρομεν ἔνδον",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 210.1.2",
      "text": "πορφυρέοις μήλοισιν ἐοικότα παῖδα Κυθήρης.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 210.1.3",
      "text": "οὐ δ’ ἔχεν ἰοδόκον φαρέτρην, οὐ καμπύλα τόξα,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 210.1.4",
      "text": "ἀλλὰ τὰ μὲν δένδρεσσιν ὑπ’ εὐπετάλοισι κρέμαντο·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 210.5.1",
      "text": "αὐτὸς δ’ ἐν καλύκεσσι ῥόδων πεπεδημένος ὕπνῳ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 210.5.2",
      "text": "εὗδεν μειδιόων· ξουθαὶ δ’ ἐφύπερθε μέλισσαι,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 210",
      "text": "κηροχυτοῦσαι ’ντός, λαροῖς ἐπὶ χείλεσι βαῖνον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 248.1",
      "text": "Τὸν Σάτυρον Διόδωρος ἐκοίμισεν, οὐκ ἐτόρευσεν·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 248",
      "text": "ἢν νύξῃς, ἐγερεῖς· ἄργυρος ὕπνον ἔχει.",
      "witness_prefix": "",
      "speaker": null
    }
  ],
