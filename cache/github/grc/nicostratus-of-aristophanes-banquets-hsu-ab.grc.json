      "kind": "text",
      "reference": "book 1-2.1",
      "text": "[spk_α]Α. Τῶν κατεσταμνισμένων ἡμῖν λαγύνων",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1-2.2",
      "text": "πηλίκοι",
      "witness_prefix": "",
