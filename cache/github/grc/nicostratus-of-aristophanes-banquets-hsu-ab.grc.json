    {
      "kind": "text",
      "reference": "book 2.1",
      "text": "[spk_β]Κἀγώ, φιλτάτη, μετανιπτρίδ’ αὐτῷ τῆς ὑγιείας ἔγχεον. Β. λαβὲ τῆς ὑγιείας δὴ σύ. φέρε, τύχἀγαθῇ. τύχη τὰ θνητῶν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.2",
      "text": "πράγμαθ’, ἡ πρόνοια δέ[ln_5]τυφλόν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 2.3",
      "text": "τι κἀσύντακτόν ἐστιν, ὦ πάτερ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.1",
      "text": "Ἀλλ’ ἐγχέασα θᾶττον ἀγαθοῦ δαίμονος ἀπενεγκάτω μοι τὴν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.2",
      "text": "τράπεζαν ἐκ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.3",
      "text": "ποδῶν· ἱκανῶς κεχόρτασμαι γάρ. ἀγαθοῦ δαίμονος δέχομαι. λαβοῦς’ ἀπένεγκε",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.4",
      "text": "ταύτην ἐκ",
      "witness_prefix": "",
      "speaker": null
    },
    {
