    {
      "kind": "text",
      "reference": "book 2",
      "text": "Ταῦτ’ ἀξιῶ. εἴτ’ ὀρνιθάριον, τὸ περιστέριον, τὸ γάστριον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1",
      "text": "Μετανιπτρίδ’ αὐτῷ τῆς ὑγιείας ἔγχεον.",
