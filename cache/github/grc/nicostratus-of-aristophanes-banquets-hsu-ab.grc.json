      "reference": "book 1-2.1",
      "text": "Βυζάντιόν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1-2.2",
      "text": "τε τέμαχος ἐπιβακχευσάτω, Γαδειρικόν θ’ ὑπογάστριον",
