      "kind": "text",
      "reference": "33.1",
      "text": "ὁ δὲ σκύφος με τοῦ θεοῦ καλεῖ πάλαι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "33.2",
      "text": "τὸ γράμμα φαίνων· δέλτ’, ἰῶτα καὶ τρίτον",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "33.3",
      "text": "οὖ, νῦ τό τ’ ὖ πάρεστι, κοὐκ ἀπουσίαν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "33.4",
      "text": "ἐκ τοὐπέκεινα σὰν τό τ’ οὖ κηρύσσετον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "34.1",
      "text": "ἡλίσκετ’ ἆρα καὶ πρὸς ἀσθενῶν ταχύς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "34.2",
      "text": "καὶ πρὸς χελώνης αἰετὸς βραχεῖ χρόνῳ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "35",
      "text": "Φαναῖος Ἀπόλλων.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "title",
      "reference": "t18",
      "text": "ΠΕΙΡΙΘΟΥΣ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "36",
      "text": "ἀμφερκῆ πίθον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "title",
      "reference": "t19",
      "text": "ΦΙΛΟΚΤΗΤΗΣ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "speaker",
      "reference": "s19",
      "text": "ΑΓΑΜΕΜΝΩΝ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "37.1",
      "text": "ὥρα βοηθεῖν ἐστ’· ἐγὼ δ’ ἡγήσομαι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "37.2",
      "text": "προσβαλλέτω τις χεῖρα φασγάνου λαβῇ,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "37.3",
      "text": "σάλπιγγι δ’ ἄλλος ὡς τάχος σημαινέτω·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "37.4",
      "text": "ὥρα ταχύνειν, ἐλελελεῦ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "title",
      "reference": "t20",
      "text": "ΦΡΙΞΟΣ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "38",
      "text": "Πελεός.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "title",
      "reference": "t21",
      "text": "ΑΔΗΛΑ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "40",
      "text": "Ταραντῖναι βαφαί.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "41",
      "text": "ἐδεξιοῦτο Βιβλίνου μέθης ἐκπώματι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "42",
      "text": "ἦ τοσούσδ’ Αἴτνη τρέφει κοχλίας κεράστας;",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "44",
      "text": "ἥκω πεπραγὼς δεινά, σὺ δ’ ὑγίαινέ μοι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "47",
      "text": "χάσκοντα λιμῷ μόσχον ὡς χελιδόνος.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "48",
      "text": "αἰόλη.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "49*",
      "text": "καιρότερον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "50",
      "text": "κύτταροι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "51?",
      "text": "μάλευρον.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "52",
      "text": "νυμφόβας.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "53?",
      "text": "πανόπτης.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "54",
      "text": "ἀλιάποδα.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "55",
      "text": "δραχμῇ παχείᾳ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "56*",
      "text": "οἴνη.",
      "witness_prefix": "",
