      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 4.5",
      "text": "τοῖσι δ’ ἔργοις ὄντας ἀνοήτους ὁρῶ.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 5",
      "text": "ἀποτετύχηται",
