      "reference": "book 3.4",
      "text": "ποιεῖν γὰρ τὰς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 3.5",
      "text": "τραπέζας οἴομαι αὐτόν, κατασκήπτοντά γ’ αὐταῖς τῇ γνάθῳ.",
