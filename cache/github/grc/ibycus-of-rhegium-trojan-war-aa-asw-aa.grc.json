    {
      "kind": "text",
      "reference": "book 35.1",
      "text": "ποικίλα ῥέγματα 〈καὶ〉 καλύπτρας",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 35.2",
      "text": "περόνας τ’ ἀναλυσαμένα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 36a.1",
      "text": "τοῦ μὲν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 36a.2",
      "text": "πετάλοισιν ἐπ’ ἀκροτάτοις ἱζάνοισι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 36a.3",
      "text": "ποικίλαι αἰολόδειροι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 36a.4",
      "text": "πανέλοπες λαθιπορφυρίδες 〈τε〉 καὶ [para]ἀλκυόνες",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 36a.5",
      "text": "τανυσίπτεροι.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 36b.1",
      "text": "αἰεί μ’ ὦ φίλε θυμὲ τανύπτερος ὡς ὅκα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 36b.2",
      "text": "πορφυρίς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 37a",
      "text": "οὔτι κατὰ σφετερὰν ἐελδώ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 37b",
      "text": "ἐσθλὸν †προδεδεγμένον† ἐέλδωρ",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 38",
      "text": "κλάδον Ἐνυαλίου,",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 39.1",
      "text": "οὐδὲ Κυάρας ὁ Μηδείων",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 39.2",
      "text": "στρατηγός.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 40.1",
      "text": "†παρὰ χέρσον λίθινον τῶν† παλάμαις βροτῶν· πρόσθεν νιν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 40.2",
      "text": "πεδ’ ἀναριτᾶν ἰχθύες ὠμοφάγοι νέμοντο.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 48",
      "text": "διέφρασαι·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 49",
      "text": "κύματος ἔξοθεν ἄκρου πᾶσα κάλως ἀσινής.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 51",
      "text": "ἤλσατο βοῦς·",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
