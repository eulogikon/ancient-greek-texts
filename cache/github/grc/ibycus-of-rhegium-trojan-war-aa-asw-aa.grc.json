      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 53",
      "text": "Λεβυαφιγενής.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 56.1",
