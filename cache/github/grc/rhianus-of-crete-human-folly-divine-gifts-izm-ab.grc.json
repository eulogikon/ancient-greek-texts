      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 34.2",
      "text": "Χαῦνοί τε καὶ αὐχήεντες Ἐλινοί",
      "witness_prefix": "",
      "speaker": null
    },
    {
