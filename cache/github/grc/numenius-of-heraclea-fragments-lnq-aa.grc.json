      "reference": "book 582.1",
      "text": "φύλλων δ’ ὅσς’ ἄσπαρτα τά τ’ ἐρρίζωται ἀρούραις",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 582.2",
      "text": "χείματος ἠδ’ ὁπόταν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 582.3",
