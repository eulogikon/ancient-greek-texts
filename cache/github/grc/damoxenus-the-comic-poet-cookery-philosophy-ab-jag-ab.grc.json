    },
    {
      "kind": "text",
      "reference": "book 1.1",
      "text": "[ln_30][spk_β]ὁ χυμὸς ὁμαλῶς",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.2",
      "text": "πανταχοῦ συνίσταται. χυμὸς λέγεις Δημόκριτος οὐδὲν",
