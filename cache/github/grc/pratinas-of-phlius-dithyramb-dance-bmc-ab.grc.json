    {
      "kind": "text",
      "reference": "book 1.6",
      "text": "τε πυγμαχίαισι νέων θέλοι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.7",
      "text": "παροίνων ἔμμεναι",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.8",
      "text": "στρατηλάτας.",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.1",
      "text": "[ln_10]παῖε τὸν",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.2",
      "text": "φρυνεοῦ ποικίλου",
