      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.3",
      "text": "πνοὰν ἔχοντα, φλέγε τὸν ὀλεσισιαλοκάλαμον λαλοβαρύοπα",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.4",
      "text": "παραμελορυθμοβάταν ὑπαὶ τρυπάνωι δέμας",
      "witness_prefix": "",
      "speaker": null
    },
