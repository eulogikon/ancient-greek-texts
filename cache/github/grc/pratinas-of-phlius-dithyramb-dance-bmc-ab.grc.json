    {
      "kind": "text",
      "reference": "book 1.4",
      "text": "Πιερὶς βασίλειαν· ὁ δ’ αὐλὸς ὕστερον",
      "witness_prefix": "",
      "speaker": null
    },
    {
      "kind": "text",
      "reference": "book 1.5",
      "text": "χορευέτω· καὶ γάρ ἐσθ’ ὑπηρέτας. κώμωι μόνον θυραμάχοις",
