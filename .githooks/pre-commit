#!/bin/sh
# Public data-store guard. Only the published surface extensions
# (.pdf / .md / .txt / .json for any mirrored kind; .epub for works only)
# at the mirrored paths, plus the small set of archive/readme docs, may
# be committed — nothing else, ever. The README already states that
# md/txt sit alongside the PDFs; .json carries the per-entity structured
# data export; .epub is the works-only self-contained reading artefact
# (authors are a navigation hub, not a reading unit, and have no .epub).
# Activate once with:
#   git config core.hooksPath .githooks
allow='^(en|affiliations|domains)/.*\.(pdf|md|txt|json)$|^grc/[^/]+/[^/]+\.(pdf|md|txt|json|epub)$|^(README|CONTRIBUTING|LICENSE)(\.md)?$|^\.gitignore$|^\.gitattributes$|^\.githooks/pre-commit$|^docs/(MISSION|CLAUDE)\.md$'
bad=$(git diff --cached --name-only --diff-filter=ACMR | grep -Ev "$allow")
if [ -n "$bad" ]; then
  echo "pre-commit: blocked — only published surfaces + archive docs may be committed:" >&2
  echo "$bad" | sed 's/^/  /' >&2
  exit 1
fi
# Refuse back-office leakage in any staged text doc (md/txt/json + the
# small repo-meta files). PDFs are binary; back-office leakage there is
# the upstream PDF generator's responsibility, not this guard's.
leak=$(git diff --cached -U0 --diff-filter=ACMR -- '*.md' '*.txt' '*.json' '.gitignore' '.gitattributes' \
  | grep -nE '^\+' \
  | grep -EI 'EULOGIKON_STRICT_DB|venv/bin|scripts/generation|src/core/|/Users/|psycopg|localhost:5432|/GitHub/|DATABASE_URL|\.env\b')
if [ -n "$leak" ]; then
  echo "pre-commit: blocked — internal/back-office reference in staged docs:" >&2
  echo "$leak" | sed 's/^/  /' >&2
  exit 1
fi
